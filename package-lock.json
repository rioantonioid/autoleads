function getDashConfig(){
  const saved=G('al_dash_config');
  if(saved&&saved.order) return saved;
  const sections=getDashSections();
  return {order:sections.map(s=>s.id),hidden:[]};
}

function saveDashConfig(cfg){S('al_dash_config',cfg)}

function filtDash(){
  const allLeads=getVisibleLeads();const sts=G('al_statuses');
  const mon=$('dashMonth')?.value||'All';
  const yr=$('dashYear')?.value||'All';
  const leads=allLeads.filter(l=>{
    if(l.status==='LOST')return false;
    if(mon!=='All'&&!l.date.startsWith(mon))return false;
    if(yr!=='All'&&mon==='All'&&!l.date.startsWith(yr))return false;
    return true;
  });

  const total=leads.length,spk=leads.filter(l=>l.status==='SPK').length;
  const hot=leads.filter(l=>l.status==='Hot').length;
  const doCount=leads.filter(l=>l.doSection).length;
  const td=new Date().toISOString().split('T')[0];
  const fups=leads.filter(l=>l.followUp&&l.followUp<=td&&!['SPK','LOST'].includes(l.status)).length;
  const isManager=['director','admin','branch_manager','sales_manager'].includes(CU.role);

  // Build section content map
  const sec={};

  // Stats
  const cards=isManager?[
    {l:'Total Leads',v:total,c:'var(--acc)',bg:'var(--acc-g)'},
    {l:'Hot',v:hot,c:'var(--red)',bg:'var(--red-g)'},
    {l:'SPK',v:spk,c:'var(--grn)',bg:'var(--grn-g)'},
    {l:'DO',v:doCount,c:'var(--pur)',bg:'var(--pur-g)'}
  ]:[
    {l:'Total Leads',v:total,c:'var(--acc)',bg:'var(--acc-g)'},
    {l:'Hot',v:hot,c:'var(--red)',bg:'var(--red-g)'},
    {l:'SPK',v:spk,c:'var(--grn)',bg:'var(--grn-g)'},
    {l:'Follow Ups Due',v:fups,c:'var(--org)',bg:'var(--org-g)'}
  ];
  sec.stats=`<div class="sg">${cards.map(s=>`<div class="sc"><div class="sc-bar" style="background:${s.c}"></div><div class="sc-icon" style="background:${s.bg}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${s.c}" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg></div><div class="sc-v" style="color:${s.c}">${s.v}</div><div class="sc-l">${s.l}</div></div>`).join('')}</div>`;

  // Checkin
  sec.checkin=renderCheckinCard();

  // Charts
  const sc=sts.filter(s=>s!=='LOST').map(s=>({s,c:leads.filter(l=>l.status===s).length}));const mx=Math.max(...sc.map(x=>x.c),1);
  const srcs=G('al_sources');const srcC2=srcs.map(s=>({s,c:leads.filter(l=>l.source===s).length})).filter(x=>x.c>0).sort((a,b)=>b.c-a.c);const mxS=Math.max(...srcC2.map(x=>x.c),1);const srcTotal=srcC2.reduce((a,x)=>a+x.c,0);
  sec.charts=`<div class="chart-row"><div class="chart-card"><div class="chart-title">Leads by Status</div><div class="bar-chart">${sc.map(x=>`<div class="bar-col"><div class="bar-v" style="color:${sC(x.s)}">${x.c}</div><div class="bar-f" style="height:${(x.c/mx)*100}px;background:${sC(x.s)}"></div><div class="bar-l">${x.s}</div></div>`).join('')}</div></div><div class="chart-card"><div class="chart-title">Leads by Source <span style="font-weight:400;color:var(--t3)">(${srcTotal} total)</span></div>${srcC2.length?srcC2.map(x=>`<div class="h-bar"><div class="h-bar-label">${x.s}</div><div class="h-bar-track"><div class="h-bar-fill" style="width:${(x.c/mxS)*100}%;background:${srcC(x.s)}"></div></div><div class="h-bar-val">${x.c}</div></div>`).join(''):'<div class="empty-s">No data</div>'}</div></div>`;

  // Sales performance
  if(pViewAll()){
    const users=G('al_users').filter(u=>u.role==='sales'&&u.active);const allL=leads;const today=new Date().toISOString().split('T')[0];
    const perf=users.map(u=>{
      const uLeads=allL.filter(l=>l.createdBy===u.username);
      const todayCount=G('al_leads').filter(l=>(l.updatedAt===today&&l.updatedBy===u.username)||(l.createdAt===today&&l.createdBy===u.username&&!l.updatedAt)).length;
      return {n:u.fullName,sup:userById(u.supervisorId),t:uLeads.length,s:uLeads.filter(l=>l.status==='SPK').length,td:todayCount};
    }).sort((a,b)=>b.t-a.t);
    const mxP=Math.max(...perf.map(x=>x.t),1);
    sec.perf=`<div class="chart-card" style="margin-bottom:20px"><div class="chart-title">Sales Performance by Person</div>${perf.map(x=>{
      const low=x.td<3;
      return `<div class="h-bar"><div class="h-bar-label"><span style="${low?'color:var(--red);font-weight:700':''}">${x.n}</span>${low?'<span style="font-size:8px;color:var(--red);margin-left:4px">⚠ '+x.td+' today</span>':' <span style="font-size:8px;color:var(--grn)">✓ '+x.td+' today</span>'}<br><span style="font-size:8px;color:var(--t4)">Sup: ${x.sup?x.sup.fullName:'—'}</span></div><div class="h-bar-track"><div class="h-bar-fill" style="width:${(x.t/mxP)*100}%;background:${low?'var(--red)':'var(--acc)'}"></div></div><div class="h-bar-val">${x.t} <span style="color:var(--grn);font-size:9px">${x.s} SPK</span></div></div>`;
    }).join('')}</div>`;
  }

  // Team performance
  if(CU.role==='supervisor'){
    const teamU=G('al_users').filter(u=>u.supervisorId===CU.id&&u.active);const allL=leads;const today2=new Date().toISOString().split('T')[0];
    const perf=teamU.map(u=>{
      const uLeads=allL.filter(l=>l.createdBy===u.username);
      const todayCount=G('al_leads').filter(l=>(l.updatedAt===today2&&l.updatedBy===u.username)||(l.createdAt===today2&&l.createdBy===u.username&&!l.updatedAt)).length;
      return {n:u.fullName,t:uLeads.length,s:uLeads.filter(l=>l.status==='SPK').length,td:todayCount};
    }).sort((a,b)=>b.t-a.t);
    const mxP=Math.max(...perf.map(x=>x.t),1);
    if(perf.length) sec.team=`<div class="chart-card" style="margin-bottom:20px"><div class="chart-title">My Team Performance</div>${perf.map(x=>{
      const low=x.td<3;
      return `<div class="h-bar"><div class="h-bar-label"><span style="${low?'color:var(--red);font-weight:700':''}">${x.n}</span>${low?'<span style="font-size:8px;color:var(--red);margin-left:4px">⚠ '+x.td+' today</span>':' <span style="font-size:8px;color:var(--grn)">✓ '+x.td+' today</span>'}</div><div class="h-bar-track"><div class="h-bar-fill" style="width:${(x.t/mxP)*100}%;background:${low?'var(--red)':'var(--org)'}"></div></div><div class="h-bar-val">${x.t} <span style="color:var(--grn);font-size:9px">${x.s} SPK</span></div></div>`;
    }).join('')}</div>`;
  }

  // Recent leads
  sec.recent=`<div class="tc"><div class="th"><div class="th-t">Recent Leads</div></div><div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Car</th><th>Status</th><th>Source</th><th>Sales</th><th>Supervisor</th><th>Follow Up</th></tr></thead><tbody>${leads.slice(0,10).map(lRow).join('')}</tbody></table></div></div>`;

  // Schedule
  if(isManager||CU.role==='supervisor') sec.schedule=buildDashSchedule();

  // Render in configured order
  const cfg=getDashConfig();
  const available=getDashSections();
  const order=cfg.order.filter(id=>available.find(s=>s.id===id));
  // Add any new sections not in saved order
  available.forEach(s=>{if(!order.includes(s.id)) order.push(s.id)});

  let h='';
  order.forEach(id=>{
    if(cfg.hidden.includes(id)) return;
    if(sec[id]) h+=sec[id];
  });

  $('dashBody').innerHTML=h;
}

function openDashConfig(){if(!['director','admin'].includes(CU.role))return;
  $('side').classList.remove('open');$('sideOv').classList.add('hidden');
  const cfg=getDashConfig();
  const sections=getDashSections();
  const order=cfg.order.filter(id=>sections.find(s=>s.id===id));
  sections.forEach(s=>{if(!order.includes(s.id)) order.push(s.id)});

  let items=order.map((id,i)=>{
    const s=sections.find(x=>x.id===id);if(!s) return '';
    const hidden=cfg.hidden.includes(id);
    const isFirst=i===0;const isLast=i===order.length-1;
    return `<div style="display:flex;align-items:center;gap:8px;padding:10px 12px;background:${hidden?'var(--bg3)':'#fff'};border:1px solid var(--bdr);border-radius:var(--r);${hidden?'opacity:.5':''}">
      <div style="display:flex;flex-direction:column;gap:2px">
        <button class="sch-nav-btn" style="padding:2px 8px;font-size:10px;${isFirst?'opacity:.2;pointer-events:none':''}" onclick="dashMoveSection('${id}',-1)">▲</button>
        <button class="sch-nav-btn" style="padding:2px 8px;font-size:10px;${isLast?'opacity:.2;pointer-events:none':''}" onclick="dashMoveSection('${id}',1)">▼</button>
      </div>
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-weight:700;color:var(--t1)">${s.icon} ${s.title}</div>
      </div>
      <label style="position:relative;width:38px;height:22px;flex-shrink:0">
        <input type="checkbox" ${hidden?'':'checked'} ${s.always?'disabled':''} onchange="dashToggleSection('${id}',this.checked)" style="opacity:0;width:0;height:0">
        <span style="position:absolute;cursor:${s.always?'not-allowed':'pointer'};top:0;left:0;right:0;bottom:0;background:${hidden?'var(--bdr)':'var(--acc)'};border-radius:22px;transition:.3s"></span>
        <span style="position:absolute;height:18px;width:18px;left:${hidden?'2':'18'}px;top:2px;background:#fff;border-radius:50%;transition:.3s;box-shadow:0 1px 3px rgba(0,0,0,.2)"></span>
      </label>
    </div>`;
  }).join('');

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:400px">
    <div class="md-h"><span class="md-t">⚙ Customize Dashboard</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="font-size:11px;color:var(--t4);margin-bottom:10px">Reorder sections with ▲▼ arrows. Toggle visibility with switches.</div>
      <div id="dashCfgList" style="display:flex;flex-direction:column;gap:6px">${items}</div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="dashResetConfig()">Reset Default</button><button class="btn btn-p" onclick="closeMd();filtDash()">Done</button></div>
  </div></div>`;
}

function dashToggleSection(id,visible){
  const cfg=getDashConfig();
  if(visible) cfg.hidden=cfg.hidden.filter(h=>h!==id);
  else if(!cfg.hidden.includes(id)) cfg.hidden.push(id);
  saveDashConfig(cfg);
  openDashConfig();
}

function dashMoveSection(id,dir){
  const cfg=getDashConfig();
  const sections=getDashSections();
  if(!cfg.order.length) cfg.order=sections.map(s=>s.id);
  const i=cfg.order.indexOf(id);if(i<0) return;
  const ni=i+dir;if(ni<0||ni>=cfg.order.length) return;
  [cfg.order[i],cfg.order[ni]]=[cfg.order[ni],cfg.order[i]];
  saveDashConfig(cfg);
  openDashConfig();
}

function dashResetConfig(){
  S('al_dash_config',null);
  closeMd();filtDash();toast('Dashboard reset to default');
}

/* Sidebar Customization */
function getAllNavItems(){
  const canLost=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const canPerf=CU.role!=='sales';
  const canSim=['director','admin','branch_manager','sales_manager','supervisor'].includes(CU.role);
  const isSup=CU.role==='supervisor';
  const items=[
    {id:'dashboard',label:'📊 Dashboard',always:true},
    {id:'stock',label:'📦 Stock'},
    {id:'leads',label:'📋 Leads',always:true},
    {id:'spk',label:'📦 SPK Results'},
    {id:'dolist',label:'🚚 DO Results'},
    {id:'lost',label:'💀 Lost Leads',show:canLost},
    {id:'perf',label:'📈 Sales Performance',show:canPerf},
    {id:'similar',label:'🔍 Similar Numbers',show:canSim},
    {id:'schedule',label:'📅 Sales Schedule'},
    {id:'events',label:'🎯 Activity'},
    {id:'team',label:'👥 My Team',show:isSup},
    {id:'users',label:'⚙ Users',show:pUsers()},
    {id:'settings',label:'🔧 Settings',show:pSettings()}
  ];
  return items.filter(i=>i.show===undefined||i.show);
}

function getSideConfig(){
  const saved=G('al_side_config');
  if(saved&&saved.order) return saved;
  return {order:getAllNavItems().map(i=>i.id),hidden:[]};
}

function saveSideConfig(cfg){S('al_side_config',cfg);buildNav();go(PAGE)}

function openSideConfig(){if(!['director','admin'].includes(CU.role))return;
  $('side').classList.remove('open');$('sideOv').classList.add('hidden');
  const cfg=getSideConfig();
  const items=getAllNavItems();
  const order=cfg.order.filter(id=>items.find(i=>i.id===id));
  items.forEach(i=>{if(!order.includes(i.id)) order.push(i.id)});

  let list=order.map((id,i)=>{
    const it=items.find(x=>x.id===id);if(!it) return '';
    const hidden=cfg.hidden.includes(id);
    const isFirst=i===0;const isLast=i===order.length-1;
    return `<div style="display:flex;align-items:center;gap:8px;padding:10px 12px;background:${hidden?'var(--bg3)':'#fff'};border:1px solid var(--bdr);border-radius:var(--r);${hidden?'opacity:.5':''}">
      <div style="display:flex;flex-direction:column;gap:2px">
        <button class="sch-nav-btn" style="padding:2px 8px;font-size:10px;${isFirst?'opacity:.2;pointer-events:none':''}" onclick="sideMove('${id}',-1)">▲</button>
        <button class="sch-nav-btn" style="padding:2px 8px;font-size:10px;${isLast?'opacity:.2;pointer-events:none':''}" onclick="sideMove('${id}',1)">▼</button>
      </div>
      <div style="flex:1;font-size:12px;font-weight:600;color:var(--t1)">${it.label}</div>
      <label style="position:relative;width:38px;height:22px;flex-shrink:0">
        <input type="checkbox" ${hidden?'':'checked'} ${it.always?'disabled':''} onchange="sideToggle('${id}',this.checked)" style="opacity:0;width:0;height:0">
        <span style="position:absolute;cursor:${it.always?'not-allowed':'pointer'};top:0;left:0;right:0;bottom:0;background:${hidden?'var(--bdr)':'var(--acc)'};border-radius:22px;transition:.3s"></span>
        <span style="position:absolute;height:18px;width:18px;left:${hidden?'2':'18'}px;top:2px;background:#fff;border-radius:50%;transition:.3s;box-shadow:0 1px 3px rgba(0,0,0,.2)"></span>
      </label>
    </div>`;
  }).join('');

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:400px">
    <div class="md-h"><span class="md-t">☰ Customize Sidebar</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="font-size:11px;color:var(--t4);margin-bottom:10px">Reorder menu items with ▲▼. Toggle visibility with switches.</div>
      <div style="display:flex;flex-direction:column;gap:6px">${list}</div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="sideReset()">Reset Default</button><button class="btn btn-p" onclick="closeMd()">Done</button></div>
  </div></div>`;
}

function sideToggle(id,visible){
  const cfg=getSideConfig();
  if(visible) cfg.hidden=cfg.hidden.filter(h=>h!==id);
  else if(!cfg.hidden.includes(id)) cfg.hidden.push(id);
  saveSideConfig(cfg);openSideConfig();
}

function sideMove(id,dir){
  const cfg=getSideConfig();
  const items=getAllNavItems();
  if(!cfg.order.length) cfg.order=items.map(i=>i.id);
  const i=cfg.order.indexOf(id);if(i<0) return;
  const ni=i+dir;if(ni<0||ni>=cfg.order.length) return;
  [cfg.order[i],cfg.order[ni]]=[cfg.order[ni],cfg.order[i]];
  saveSideConfig(cfg);openSideConfig();
}

function sideReset(){
  S('al_side_config',null);
  closeMd();buildNav();go(PAGE);toast('Sidebar reset to default');
}

function buildDashSchedule(){
  const schedules=G('al_schedules')||[];
  const events=G('al_events')||[];
  const salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active);
  if(!salesUsers.length) return '';

  // Get this week Mon-Sun
  const today=new Date();
  const todayStr=localDate(today);
  const weekStart=new Date(today);
  const dow=weekStart.getDay();
  weekStart.setDate(weekStart.getDate()-(dow===0?6:dow-1));
  const week=[];
  for(let i=0;i<7;i++){const d=new Date(weekStart);d.setDate(d.getDate()+i);week.push(d)}

  const dayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  // Count unassigned per day
  let totalUnassigned=0;
  week.forEach(d=>{
    const ds=localDate(d);
    salesUsers.forEach(u=>{
      if(!schedules.find(s=>s.date===ds&&s.username===u.username)) totalUnassigned++;
    });
  });

  // Sort users by supervisor
  const sorted=[...salesUsers].sort((a,b)=>{
    const sa=a.supervisorId||999;const sb=b.supervisorId||999;
    if(sa!==sb) return sa-sb;
    return a.fullName.localeCompare(b.fullName);
  });

  let h=`<div class="chart-card" style="margin-top:20px;padding:0;overflow:hidden">
    <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--bdr)">
      <div>
        <div class="chart-title" style="margin:0">📅 This Week's Schedule</div>
        <div style="font-size:10px;color:var(--t4);margin-top:2px">${localDate(week[0])} → ${localDate(week[6])}</div>
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        ${totalUnassigned?`<span style="background:var(--red-g);color:var(--red);font-size:10px;font-weight:700;padding:3px 8px;border-radius:10px">${totalUnassigned} unassigned</span>`:`<span style="background:var(--grn-g);color:var(--grn);font-size:10px;font-weight:700;padding:3px 8px;border-radius:10px">✓ All assigned</span>`}
        <button class="btn btn-p btn-sm" onclick="go('schedule')" style="font-size:10px">Manage →</button>
      </div>
    </div>
    ${(()=>{const ew=getEvtWarnings();if(!ew.length) return '';let a=`<div style="padding:10px 16px;background:rgba(239,68,68,.04);border-bottom:1px solid rgba(239,68,68,.1)">`;ew.forEach((w,wi)=>{const c=w.event.color||EVT_COLORS[0];const sd=w.days.filter(d=>d.short);a+=`<div style="display:flex;align-items:flex-start;gap:8px;${wi<ew.length-1?'margin-bottom:8px':''}"><div style="font-size:14px;line-height:1">⚠</div><div style="flex:1;min-width:0"><div style="font-size:11px;font-weight:700;color:var(--red)"><span style="color:${c}">🎯 ${w.event.name}</span> — needs ${MIN_STAFF}+ sales</div><div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:3px">${sd.map(d=>{const dn=new Date(d.date).toLocaleDateString('en',{weekday:'short',day:'numeric',month:'short'});return `<span style="font-size:8px;padding:2px 6px;border-radius:4px;background:var(--red-g);color:var(--red);font-weight:600">${dn}: ${d.count}/${MIN_STAFF}</span>`}).join('')}</div></div><button class="btn btn-s btn-sm" onclick="go('schedule')" style="font-size:8px;flex-shrink:0">Fix →</button></div>`});a+=`</div>`;return a})()}
    <div class="sch-scroll" style="border:none;box-shadow:none;border-radius:0">
      <div class="sch-grid" style="border:none;border-radius:0;box-shadow:none;min-width:700px">
        <div class="sch-hdr" style="border-right:1px solid var(--bdr)">Sales</div>`;

  week.forEach((d,i)=>{
    const ds=localDate(d);
    const isToday=ds===todayStr;
    h+=`<div class="sch-hdr" style="${isToday?'background:var(--acc);color:#fff':''}">${dayNames[i]}<br>${d.getDate()}</div>`;
  });

  sorted.forEach(u=>{
    const sup=userById(u.supervisorId);
    h+=`<div class="sch-name-col" style="min-height:50px">
      <div class="perf-av rc-sales" style="width:20px;height:20px;font-size:7px">${initials(u.fullName)}</div>
      <div style="min-width:0;overflow:hidden"><div style="white-space:nowrap;text-overflow:ellipsis;overflow:hidden;font-size:10px">${u.fullName}</div></div>
    </div>`;

    week.forEach(d=>{
      const ds=localDate(d);
      const isToday=ds===todayStr;
      const entry=schedules.find(s=>s.date===ds&&s.username===u.username);
      const hasShift=entry&&entry.shift;
      const base=hasShift?BASE_SHIFTS.find(s=>s.id===entry.shift):null;
      const evt=entry&&entry.eventId?(events.find(e=>e.id===entry.eventId)):null;
      const unassigned=!hasShift;

      h+=`<div class="sch-cell readonly${isToday?' today':''}" style="min-height:50px;${unassigned?'background:rgba(239,68,68,.04)':''}">`;
      if(hasShift&&base){
        const c=base.color;
        h+=`<div class="sch-shift" style="background:${c}20;color:${c};font-size:9px">${base.icon} ${base.label}</div>`;
        if(evt){
          const ec=evt.color||'#7C3AED';
          h+=`<div style="font-size:8px;color:${ec};font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px">🎯 ${evt.name}</div>`;
        }
      }else{
        h+=`<div style="font-size:9px;color:var(--red);text-align:center;padding:4px 0;opacity:.5">—</div>`;
      }
      h+=`</div>`;
    });
  });

  h+=`</div></div></div>`;
  return h;
}

function lRow(l){
  const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
  const dup=isDupe(l.id)?'<span class="dupe-badge">⚠ DUPLICATE</span>':'';
  return `<tr onclick="openLD(${l.id})"><td><strong style="font-size:12px">${l.name}</strong>${dup}<div style="font-size:10px;color:var(--t4)">${l.phone}</div></td><td style="font-size:11px">${l.carType}</td><td><span class="badge" style="background:${sBg(l.status)};color:${sC(l.status)}"><span class="bdot" style="background:${sC(l.status)}"></span>${l.status}</span></td><td><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:9px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></td><td style="font-size:11px">${u?u.fullName:l.createdBy}</td><td style="font-size:10px;color:var(--t4)">${sup?sup.fullName:'—'}</td><td style="font-size:10px">${fuCountdown(l.followUp)}</td></tr>`;
}

/* ═══════════════════════════════════════
   LEADS TABLE
   ═══════════════════════════════════════ */
function monthOpts(leads){
  const months=new Set();
  leads.forEach(l=>{if(l.date)months.add(l.date.slice(0,7))});
  const sorted=[...months].sort().reverse();
  const labels=sorted.map(m=>{const [y,mo]=m.split('-');const mn=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][parseInt(mo)-1];return {v:m,l:mn+' '+y}});
  return `<option value="All">All Months</option>${labels.map(m=>`<option value="${m.v}">${m.l}</option>`).join('')}`;
}

function renderLeads(){
  const sts=G('al_statuses');const srcs=G('al_sources');
  const allLeads=getVisibleLeads().filter(l=>!l.spkSection&&!l.doSection);
  let exp=pExport()?`<button class="btn btn-s btn-sm" onclick="expCSV('leads')">📥 Export CSV</button>`:'';
  $('topA').innerHTML=`${exp}<button class="btn btn-p btn-sm" onclick="openLF()">+ New Lead</button>`;

  // Supervisor + Sales dropdowns (for roles that can see all)
  let supDD='',salesDD='';
  if(pViewAll()){
    const sups=G('al_users').filter(u=>u.role==='supervisor'&&u.active);
    const salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active);
    supDD=`<select class="fd" id="fSup" onchange="onSupChange('f','filt')"><option value="All">All Supervisors</option>${sups.map(s=>`<option value="${s.id}">${s.fullName}</option>`).join('')}</select>`;
    salesDD=`<select class="fd" id="fSales" onchange="filt()"><option value="All">All Sales</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }else if(CU.role==='supervisor'){
    const teamSales=G('al_users').filter(u=>u.role==='sales'&&u.supervisorId===CU.id&&u.active);
    salesDD=`<select class="fd" id="fSales" onchange="filt()"><option value="All">All Sales</option>${teamSales.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }

  $('pgC').innerHTML=`<div class="tc"><div class="th"><div class="th-t">All Leads</div><div class="th-c">
    <div class="sb"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input id="lSrch" placeholder="Search..." oninput="filt()"></div>
    <select class="fd" id="fMonth" onchange="filt()">${monthOpts(allLeads)}</select>
    <select class="fd" id="fSt" onchange="filt()"><option value="All">All Status</option>${sts.map(s=>`<option>${s}</option>`).join('')}</select>
    <select class="fd" id="fSrc" onchange="filt()"><option value="All">All Sources</option>${srcs.map(s=>`<option>${s}</option>`).join('')}</select>
    ${supDD}${salesDD}
  </div></div><div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Car</th><th>Status</th><th>Source</th><th>Date</th><th>Follow Up</th><th>Sales</th><th>Supervisor</th><th style="width:55px"></th></tr></thead><tbody id="lBody"></tbody></table></div></div>`;
  filt();
}

function onSupChange(prefix,filtFn){
  const supF=$(prefix+'Sup')?.value||'All';
  const salesEl=$(prefix+'Sales');
  if(!salesEl)return;
  let salesUsers;
  if(supF==='All'){
    salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active);
  }else{
    salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active&&u.supervisorId===Number(supF));
  }
  salesEl.innerHTML=`<option value="All">All Sales</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}`;
  window[filtFn]();
}

function filt(){
  let leads=getVisibleLeads().filter(l=>!l.spkSection&&!l.doSection&&l.status!=='LOST');
  const q=($('lSrch')?.value||'').toLowerCase();
  const st=$('fSt')?.value||'All';const src=$('fSrc')?.value||'All';const sal=$('fSales')?.value||'All';const mon=$('fMonth')?.value||'All';
  const supF=$('fSup')?.value||'All';
  const f=leads.filter(l=>{
    if(q&&!l.name.toLowerCase().includes(q)&&!l.phone.includes(q))return false;
    if(st!=='All'&&l.status!==st)return false;
    if(src!=='All'&&l.source!==src)return false;
    if(sal!=='All'&&l.createdBy!==sal)return false;
    if(mon!=='All'&&!l.date.startsWith(mon))return false;
    if(supF!=='All'){const u=userByUn(l.createdBy);if(!u||u.supervisorId!==Number(supF))return false}
    return true;
  });
  const b=$('lBody');if(!b)return;
  if(!f.length){b.innerHTML=`<tr><td colspan="9"><div class="empty"><div class="empty-i">📋</div><div class="empty-t">No leads found</div></div></td></tr>`;return}
  b.innerHTML=f.map(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const canE=CU.role!=='sales'||l.createdBy===CU.username;
    const dup=isDupe(l.id)?'<span class="dupe-badge">⚠ DUPLICATE</span>':'';
