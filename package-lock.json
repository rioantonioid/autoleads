function renderUsers(){
  if(!pUsers()){$('pgC').innerHTML=`<div class="empty"><div class="empty-t">Access Denied</div></div>`;return}
  const users=G('al_users');
  $('topA').innerHTML=`<button class="btn btn-p btn-sm" onclick="openUF()">+ Add User</button>`;

  let h=`<div style="margin-bottom:12px;font-size:11px;color:var(--t3)">${users.length} / 50 users</div>`;
  ['director','admin','branch_manager','sales_manager','supervisor','sales'].forEach(rid=>{
    const ru=users.filter(u=>u.role===rid);if(!ru.length)return;
    h+=`<div class="role-sec"><div class="role-sec-h"><span class="role-sec-dot" style="background:${rColor(rid)}"></span>${rLabel(rid)}s (${ru.length})</div><div class="usr-grid">`;
    ru.forEach(u=>{
      const sup=userById(u.supervisorId);
      const myLevel=R(CU.role).level;const isTop=u.role==='director'||u.role==='admin';
      const canDel=u.id!==1&&(myLevel>=5||!isTop);
      h+=`<div class="usr-card"><div class="usr-av rc-${rid}">${initials(u.fullName)}</div><div><div class="usr-name">${u.fullName}${!u.active?' <span style="color:var(--red);font-size:9px">DISABLED</span>':''}</div><div class="usr-meta">@${u.username}${sup?` · Sup: ${sup.fullName}`:''}</div></div><div class="usr-acts"><button class="abtn" onclick="openUF(${u.id})">✎</button>${canDel?`<button class="abtn del" onclick="delU(${u.id})">✕</button>`:''}</div></div>`;
    });
    h+=`</div></div>`;
  });
  $('pgC').innerHTML=h;
}

function openUF(id){
  const users=G('al_users');if(!id&&users.length>=50){toast('Max 50 users');return}
  const u=id?users.find(x=>Number(x.id)===Number(id)):null;const sups=getSupervisors();
  const myLevel=R(CU.role).level;
  const targetIsTop=u&&(u.role==='director'||u.role==='admin');
  const canEditPw=!targetIsTop||myLevel>=5; // Only Director/Admin (level 5) can edit Director/Admin passwords
  const availRoles=myLevel>=5?ROLES:ROLES.filter(r=>r.level<5); // BM/SM can't assign Director/Admin role

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md">
    <div class="md-h"><span class="md-t">${u?'Edit User':'Add User'}</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div class="fr2"><div class="fg"><label class="fl">Full Name *</label><input class="fi" id="uN" value="${u?u.fullName:''}"></div><div class="fg"><label class="fl">Username *</label><input class="fi" id="uU" value="${u?u.username:''}" ${u?'disabled':''}></div></div>
      <div class="fr2">${canEditPw?`<div class="fg"><label class="fl">${u?'New Password (blank=keep)':'Password *'}</label><input class="fi" id="uP" type="password"></div>`:`<div class="fg"><label class="fl">Password</label><div style="padding:10px 12px;background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);font-size:11px;color:var(--t4)">🔒 Protected — Only Director/Admin can change this password</div><input type="hidden" id="uP" value=""></div>`}
      <div class="fg"><label class="fl">Role *</label><select class="fs" id="uR" onchange="toggleSup()">${availRoles.map(r=>`<option value="${r.id}" ${u&&u.role===r.id?'selected':''}>${r.label}</option>`).join('')}</select></div></div>
      <div class="fg" id="supF" style="${u&&u.role==='sales'?'':'display:none'}">
        <label class="fl">Supervisor * <span class="fl-hint">(Required for Sales)</span></label>
        <select class="fs" id="uSup"><option value="">— Select Supervisor —</option>${sups.map(s=>`<option value="${s.id}" ${u&&u.supervisorId===s.id?'selected':''}>${s.fullName}</option>`).join('')}</select>
      </div>
      <div class="fg"><label class="fl">Status</label><select class="fs" id="uA"><option value="true" ${!u||u.active?'selected':''}>Active</option><option value="false" ${u&&!u.active?'selected':''}>Disabled</option></select></div>
      <div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:10px 12px;font-size:10px;color:var(--t4);line-height:1.5;margin-top:4px">
        <strong style="color:var(--t2)">Role permissions:</strong><br>
        • <strong>Director / Admin</strong> — Full access: all data, users, settings, export<br>
        • <strong>Branch / Sales Manager</strong> — Full access except Director/Admin passwords<br>
        • <strong>Supervisor</strong> — View own team only, no export<br>
        • <strong>Sales</strong> — View own leads only, no export, must select supervisor
      </div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-p" onclick="saveU(${id||0})">Save</button></div>
  </div></div>`;
}

function toggleSup(){$('supF').style.display=$('uR').value==='sales'?'block':'none'}

function saveU(id){
  const name=$('uN').value.trim(),user=$('uU').value.trim().toLowerCase(),pass=$('uP').value,role=$('uR').value,active=$('uA').value==='true';
  const supId=role==='sales'?Number($('uSup').value)||null:null;
  if(!name||(!id&&(!user||!pass))){toast('Fill required fields');return}
  if(role==='sales'&&!supId){toast('Sales must select a Supervisor!');return}
  const myLevel=R(CU.role).level;
  // BM/SM can't assign Director/Admin role
  if(myLevel<5&&(role==='director'||role==='admin')){toast('Cannot assign Director/Admin role');return}
  let users=G('al_users');
  if(id){
    const target=users.find(u=>u.id===id);
    const targetIsTop=target&&(target.role==='director'||target.role==='admin');
    // BM/SM can't change Director/Admin password
    const pwUpdate=(pass&&(!targetIsTop||myLevel>=5))?{password:pass}:{};
    users=users.map(u=>u.id===id?{...u,fullName:name,role:targetIsTop&&myLevel<5?target.role:role,supervisorId:supId,active,...pwUpdate}:u);
    toast('User updated');
  }else{
    if(users.find(u=>u.username===user)){toast('Username exists');return}
    users.push({id:Date.now(),username:user,password:pass,fullName:name,role,supervisorId:supId,active,createdAt:new Date().toISOString().split('T')[0]});
    toast('User created');
  }
  S('al_users',users);closeMd();renderUsers();buildNav();
}
function delU(id){
  const target=G('al_users').find(u=>u.id===id);
  const myLevel=R(CU.role).level;
  if(target&&(target.role==='director'||target.role==='admin')&&myLevel<5){toast('Cannot delete Director/Admin');return}
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:380px">
    <div class="md-h"><span class="md-t">🗑 Delete User</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="font-size:13px;color:var(--t2);text-align:center;padding:10px 0">Delete <b>${target?target.fullName:''}</b>?<br><span style="font-size:11px;color:var(--t4)">This action cannot be undone.</span></div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-d" onclick="confirmDelU(${id})">Delete</button></div>
  </div></div>`;
}
function confirmDelU(id){
  S('al_users',G('al_users').filter(u=>u.id!==id));closeMd();toast('User deleted');renderUsers();
}

