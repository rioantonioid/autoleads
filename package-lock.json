function handleDOPhoto(e){
  const file=e.target.files[0];if(!file)return;
  if(!file.type.startsWith('image/')){toast('Please select an image file');e.target.value='';return}
  if(file.size>10*1024*1024){toast('Photo must be under 10MB');e.target.value='';return}

  // Compress image for storage
  const img=new Image();
  const url=URL.createObjectURL(file);
  img.onload=function(){
    URL.revokeObjectURL(url);
    const canvas=document.createElement('canvas');
    let w=img.width,h=img.height;
    const maxDim=1200;
    if(w>maxDim||h>maxDim){
      if(w>h){h=Math.round(h*maxDim/w);w=maxDim}
      else{w=Math.round(w*maxDim/h);h=maxDim}
    }
    canvas.width=w;canvas.height=h;
    const ctx=canvas.getContext('2d');
    ctx.drawImage(img,0,0,w,h);
    const compressed=canvas.toDataURL('image/jpeg',0.7);
    window._doPhoto=compressed;
    const area=$('doUploadArea');
    const preview=$('doPhotoPreview');
    if(area)area.classList.add('has-photo');
    if(preview)preview.innerHTML=`<img src="${compressed}" alt="Delivery photo"><div style="font-size:10px;color:var(--grn);margin-top:4px;font-weight:600">✓ Photo attached — tap to change</div>`;
  };
  img.onerror=function(){URL.revokeObjectURL(url);toast('Failed to load image');e.target.value='';};
  img.src=url;
}

function confirmDODate(id){
  const dt=$('fDoDate').value;
