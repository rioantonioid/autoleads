  $('topA').innerHTML=pExport()?`<button class="btn btn-s btn-sm" onclick="expCSV('do')">📥 Export CSV</button><button class="btn btn-p btn-sm" onclick="expDOZip()">📦 Export ZIP (Photos + Data)</button>`:'';
