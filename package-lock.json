    salesDD=`<select class="fd" id="doSales" onchange="filtDO()"><option value="All">All Sales</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }else if(CU.role==='supervisor'){
    const teamSales=G('al_users').filter(u=>u.role==='sales'&&u.supervisorId===CU.id&&u.active);
    salesDD=`<select class="fd" id="doSales" onchange="filtDO()"><option value="All">All Sales</option>${teamSales.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }

  let h=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="display:flex;gap:10px;align-items:center">
      <div style="font-size:13px;font-weight:700;color:var(--t1)">DO Results</div>
      <div class="view-tog"><button class="${doViewMode==='cards'?'act':''}" onclick="doViewMode='cards';filtDO()">Cards</button><button class="${doViewMode==='compact'?'act':''}" onclick="doViewMode='compact';filtDO()">Compact</button></div>
    </div>
    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
      <div class="sb"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input id="doSrch" placeholder="Search..." oninput="filtDO()"></div>
      <select class="fd" id="doMonth" onchange="filtDO()">${monthOpts(allDo)}</select>
      ${supDD}${salesDD}
    </div>
  </div>`;
  h+=`<div id="doBody"></div>`;
  $('pgC').innerHTML=h;
  filtDO();
}

function filtDO(){
  const allDo=getVisibleLeads().filter(l=>l.doSection);
  const q=($('doSrch')?.value||'').toLowerCase();
  const mon=$('doMonth')?.value||'All';
  const supF=$('doSup')?.value||'All';
  const sal=$('doSales')?.value||'All';
  const leads=allDo.filter(l=>{
    if(q&&!l.name.toLowerCase().includes(q)&&!l.phone.includes(q))return false;
    if(mon!=='All'&&!((l.doDate&&l.doDate.startsWith(mon))||(!l.doDate&&l.date.startsWith(mon))))return false;
    if(sal!=='All'&&l.createdBy!==sal)return false;
    if(supF!=='All'){const u=userByUn(l.createdBy);if(!u||u.supervisorId!==Number(supF))return false}
    return true;
  });
  const body=$('doBody');if(!body)return;

  if(!leads.length){
    body.innerHTML=`<div class="empty" style="padding:60px 20px"><div class="empty-i">🚚</div><div class="empty-t">No DO found</div><div class="empty-s">${allDo.length?'Try a different filter':'Delivery orders will appear here'}</div></div>`;
    return;
  }
  let h=`<div style="margin-bottom:10px;font-size:12px;color:var(--t3)">${leads.length} DO found</div>`;
  if(doViewMode==='compact'){
    h+=`<div style="overflow-x:auto"><table class="cpt-tbl"><thead><tr><th>Name</th><th>Phone</th><th>Car</th><th>Source</th><th>Sales</th><th>Supervisor</th><th>Lead</th><th>SPK</th><th>DO</th></tr></thead><tbody>`;
    leads.forEach(l=>{
      const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
      h+=`<tr onclick="openLD(${l.id})"><td class="cpt-name">${l.name}</td><td class="cpt-phone">${l.phone}</td><td>${l.carType}</td><td><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:8px;padding:1px 5px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></td><td>${u?u.fullName:l.createdBy}</td><td>${sup?sup.fullName:'—'}</td><td class="cpt-date" style="color:var(--t2)">${l.date}</td><td class="cpt-date" style="color:var(--grn)">${l.spkDate||'—'}</td><td class="cpt-date" style="color:var(--pur)">${l.doDate||'—'}</td></tr>`;
    });
    h+=`</tbody></table></div>`;
  }else{
  leads.forEach(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const acts=getActivities(l.id);const lastAct=acts.length?acts[0]:null;
    h+=`<div class="spk-card" onclick="openLD(${l.id})">
      <div class="spk-head"><div style="display:flex;gap:10px;align-items:center">
        ${l.doPhoto?`<img src="${l.doPhoto}" class="do-photo-thumb" onclick="event.stopPropagation();viewDOPhoto(${l.id})" alt="DO">`:''}
        <div><div class="spk-name">${l.name}</div><div class="spk-phone">${l.phone}</div></div>
      </div>
      <span class="badge" style="background:var(--pur-g);color:var(--pur)"><span class="bdot" style="background:var(--pur)"></span>DO</span></div>
      <div class="spk-details">
        <span>🚗 ${l.carType}</span>
        <span><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:9px;padding:2px 6px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></span>
        <span>👤 ${u?u.fullName:l.createdBy}</span>
        ${sup?`<span>📋 ${sup.fullName}</span>`:''}
      </div>
      <div style="display:flex;gap:16px;margin-top:8px;padding-top:8px;border-top:1px solid var(--bdr);font-size:11px">
        <div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">Lead Date</span><div style="font-weight:600;color:var(--t2);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.date}</div></div>
        ${l.spkDate?`<div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">SPK Date</span><div style="font-weight:700;color:var(--grn);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.spkDate}</div></div>`:''}
        ${l.doDate?`<div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">DO Date</span><div style="font-weight:700;color:var(--pur);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.doDate}</div></div>`:''}
      </div>
      ${lastAct?`<div style="margin-top:8px;font-size:10px;color:var(--t4);border-top:1px solid var(--bdr);padding-top:6px">Last activity: ${lastAct.detail} — ${lastAct.date} ${lastAct.time}</div>`:''}
    </div>`;
  });
  } // end cards view
  body.innerHTML=h;
}

/* ═══════════════════════════════════════
   LOST LEADS
   ═══════════════════════════════════════ */
function renderLost(){
  const canLost=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  if(!canLost){$('pgC').innerHTML=`<div class="empty"><div class="empty-t">Access Denied</div></div>`;return}
  $('topA').innerHTML=pExport()?`<button class="btn btn-s btn-sm" onclick="expCSV('lost')">📥 Export Lost</button><button class="btn btn-sm" onclick="bulkDelLost()" style="background:var(--red-g);color:var(--red);border-color:var(--red);font-size:10px;margin-left:4px">🗑 Delete All Lost</button>`:'';

  const allLost=G('al_leads').filter(l=>l.status==='LOST'&&!l.spkSection&&!l.doSection);
  const users=G('al_users').filter(u=>u.active);
  const salesUsers=users.filter(u=>u.role==='sales');
  const sups=users.filter(u=>u.role==='supervisor');

  let salesOpts=`<option value="All">All Sales</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}`;
  let supOpts=`<option value="All">All Supervisors</option>${sups.map(s=>`<option value="${s.id}">${s.fullName}</option>`).join('')}`;

  let h=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="font-size:13px;font-weight:700;color:var(--t1)">💀 Lost Leads</div>
    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
      <div class="sb"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input id="lostSrch" placeholder="Search..." oninput="filtLost()"></div>
      <select class="fd" id="lostMonth" onchange="filtLost()">${monthOpts(allLost)}</select>
      <select class="fd" id="lostSales" onchange="filtLost()">${salesOpts}</select>
      <select class="fd" id="lostSup" onchange="filtLost()">${supOpts}</select>
    </div>
  </div>`;
  h+=`<div id="lostBody"></div>`;
  $('pgC').innerHTML=h;
  filtLost();
}

function filtLost(){
  const allLost=G('al_leads').filter(l=>l.status==='LOST'&&!l.spkSection&&!l.doSection);
  const q=($('lostSrch')?.value||'').toLowerCase();
  const mon=$('lostMonth')?.value||'All';
  const sal=$('lostSales')?.value||'All';
  const supF=$('lostSup')?.value||'All';

  const leads=allLost.filter(l=>{
    if(q&&!l.name.toLowerCase().includes(q)&&!l.phone.includes(q))return false;
    if(mon!=='All'&&!l.date.startsWith(mon))return false;
    if(sal!=='All'&&l.createdBy!==sal)return false;
    if(supF!=='All'){const u=userByUn(l.createdBy);if(!u||u.supervisorId!==Number(supF))return false}
    return true;
  });

  const body=$('lostBody');if(!body)return;
  if(!leads.length){
    body.innerHTML=`<div class="empty" style="padding:60px 20px"><div class="empty-i">💀</div><div class="empty-t">No lost leads found</div><div class="empty-s">${allLost.length?'Try a different filter':'No leads have been marked as LOST yet'}</div></div>`;
    return;
  }

  let h=`<div style="margin-bottom:10px;font-size:12px;color:var(--t3)">${leads.length} lost lead${leads.length!==1?'s':''}</div>`;

  leads.forEach(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const acts=getActivities(l.id);const lastAct=acts.length?acts[0]:null;
    const daysSince=l.updatedAt?Math.round((new Date()-new Date(l.updatedAt))/86400000):0;

    h+=`<div class="spk-card" style="border-left:3px solid var(--red)" onclick="openLD(${l.id})">
      <div class="spk-head">
        <div><div class="spk-name">${l.name}</div><div class="spk-phone">${l.phone}</div></div>
        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
          <button class="btn btn-p btn-sm" onclick="event.stopPropagation();reassignLead(${l.id})" style="font-size:10px">🔄 Reassign</button>
          <span class="badge" style="background:var(--red-g);color:var(--red)"><span class="bdot" style="background:var(--red)"></span>LOST</span>
        </div>
      </div>
      <div class="spk-details">
        <span>🚗 ${l.carType}</span>
        <span><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:9px;padding:2px 6px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></span>
        <span>👤 ${u?u.fullName:l.createdBy}</span>
        ${sup?`<span>📋 ${sup.fullName}</span>`:''}
        <span style="color:var(--red);font-weight:600">💀 ${daysSince}d inactive</span>
      </div>
      <div style="display:flex;gap:16px;margin-top:8px;padding-top:8px;border-top:1px solid var(--bdr);font-size:11px">
        <div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">Lead Date</span><div style="font-weight:600;color:var(--t2);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.date}</div></div>
        <div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">Last Update</span><div style="font-weight:600;color:var(--red);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.updatedAt||l.createdAt}</div></div>
      </div>
      ${lastAct?`<div style="margin-top:8px;font-size:10px;color:var(--t4);border-top:1px solid var(--bdr);padding-top:6px">Last activity: ${lastAct.detail} — ${lastAct.date} ${lastAct.time}</div>`:''}
    </div>`;
  });

  body.innerHTML=h;
}

function bulkDelLost(){
  const lost=G('al_leads').filter(l=>l.status==='LOST'&&!l.spkSection&&!l.doSection);
  if(!lost.length){toast('No lost leads to delete');return}
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:400px">
    <div class="md-h"><span class="md-t">🗑 Delete All Lost Leads</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="text-align:center;padding:10px 0">
        <div style="font-size:36px;margin-bottom:8px">⚠️</div>
        <div style="font-size:14px;font-weight:700;color:var(--red);margin-bottom:6px">This will permanently delete ${lost.length} lost lead${lost.length!==1?'s':''}</div>
        <div style="font-size:12px;color:var(--t3)">This action cannot be undone. All lost leads and their activity history will be removed.</div>
      </div>
      <div class="fg" style="margin-top:12px"><label class="fl">Type <b>DELETE</b> to confirm</label><input class="fi" id="delLostConfirm" placeholder="Type DELETE here" autocomplete="off"></div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-d" onclick="confirmBulkDelLost()">🗑 Delete All</button></div>
  </div></div>`;
}

function confirmBulkDelLost(){
  const input=$('delLostConfirm')?.value?.trim();
  if(input!=='DELETE'){toast('Please type DELETE to confirm');return}
  let leads=G('al_leads');
  const lostIds=leads.filter(l=>l.status==='LOST'&&!l.spkSection&&!l.doSection).map(l=>l.id);
  leads=leads.filter(l=>!lostIds.includes(l.id));
  S('al_leads',leads);
  // Clean up activities for deleted leads
  let acts=G('al_activities')||[];
  acts=acts.filter(a=>!lostIds.includes(a.leadId));
  S('al_activities',acts);
  closeMd();toast(`${lostIds.length} lost leads deleted`);buildNav();go('lost');
}

function reassignLead(id){
  id=Number(id);
  const l=G('al_leads').find(x=>Number(x.id)===id);if(!l)return;
  const tmr=new Date(Date.now()+86400000).toISOString().split('T')[0];
  const salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active);
  const salesOpts=salesUsers.map(u=>{
    const sup=userById(u.supervisorId);
    return `<option value="${u.username}">${u.fullName} (${rLabel(u.role)})${sup?' — Sup: '+sup.fullName:''}</option>`;
  }).join('');

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:440px">
    <div class="md-h"><span class="md-t">🔄 Reassign Lead</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:12px;margin-bottom:14px">
        <div style="font-size:14px;font-weight:700;color:var(--t1)">${l.name}</div>
        <div style="font-size:12px;color:var(--t3);margin-top:2px">${l.phone} · ${l.carType}</div>
        <div style="font-size:10px;color:var(--red);margin-top:4px">Currently: LOST · Previously: ${userByUn(l.createdBy)?userByUn(l.createdBy).fullName:l.createdBy}</div>
      </div>
      <div class="fg"><label class="fl">Assign To Sales Person *</label><select class="fs" id="reassignTo">${salesOpts}</select></div>
      <div class="fr2" style="margin-top:8px">
        <div class="fg"><label class="fl">New Status *</label><select class="fs" id="reassignSt">${G('al_statuses').filter(s=>s!=='LOST'&&s!=='SPK').map(s=>`<option>${s}</option>`).join('')}</select></div>
        <div class="fg"><label class="fl">Follow Up *</label><input class="fi" id="reassignFU" type="date" value="${tmr}"></div>
      </div>
      <div class="fg" style="margin-top:8px"><label class="fl">Note</label><input class="fi" id="reassignNote" placeholder="Instructions for the sales person..."></div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-p" onclick="confirmReassign(${id})">🔄 Reassign</button></div>
  </div></div>`;
}

function confirmReassign(id){
  const to=$('reassignTo').value;
  const st=$('reassignSt').value;
  const fu=$('reassignFU').value;
  const note=$('reassignNote').value.trim();
  if(!to){toast('Select a sales person');return}
  if(!fu){toast('Follow up date required');return}
  const now=new Date().toISOString().split('T')[0];
  const toUser=G('al_users').find(u=>u.username===to);
  let leads=G('al_leads');
  leads=leads.map(l=>Number(l.id)===Number(id)?{...l,status:st,createdBy:to,followUp:fu,updatedAt:now,updatedBy:CU.username}:l);
  S('al_leads',leads);
  addActivity(id,'status','Reassigned from LOST → '+st+' → '+(toUser?toUser.fullName:to)+(note?' — '+note:''));
  closeMd();toast('Lead reassigned to '+(toUser?toUser.fullName:to));
  buildNav();go(PAGE);
}

/* ═══════════════════════════════════════
   SALES PERFORMANCE
   ═══════════════════════════════════════ */
function renderPerf(){
  if(CU.role==='sales'){$('pgC').innerHTML=`<div class="empty"><div class="empty-t">Access Denied</div></div>`;return}
  $('topA').innerHTML=pExport()?`<button class="btn btn-s btn-sm" onclick="expPerfCSV()">📥 Export Performance</button>`:'';
  const allLeads=G('al_leads');
  const users=G('al_users').filter(u=>u.role==='sales'&&u.active);
  const sups=G('al_users').filter(u=>u.role==='supervisor'&&u.active);

  // Supervisor only sees own team
  const visibleUsers=CU.role==='supervisor'?users.filter(u=>u.supervisorId===CU.id):users;

  let supOpts=`<option value="All">All Supervisors</option>${sups.map(s=>`<option value="${s.id}">${s.fullName}</option>`).join('')}`;
  let salesOpts=`<option value="All">All Sales</option>${visibleUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}`;

  let h=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="font-size:13px;font-weight:700;color:var(--t1)">Sales Performance</div>
    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
      <select class="fd" id="perfMonth" onchange="filtPerf()">${monthOpts(allLeads)}</select>
      <select class="fd" id="perfYear" onchange="filtPerf()">${yearOpts(allLeads)}</select>
      ${CU.role!=='supervisor'?`<select class="fd" id="perfSup" onchange="filtPerf()">${supOpts}</select>`:`<input type="hidden" id="perfSup" value="${CU.id}">`}
      <select class="fd" id="perfSales" onchange="filtPerf()">${salesOpts}</select>
    </div>
  </div>`;
  h+=`<div id="perfBody"></div>`;
  $('pgC').innerHTML=h;
  filtPerf();
}

function filtPerf(){
  const allLeads=G('al_leads');
  const users=G('al_users').filter(u=>u.role==='sales'&&u.active);
  const mon=$('perfMonth')?.value||'All';
  const yr=$('perfYear')?.value||'All';
  const supF=$('perfSup')?.value||'All';
  const salF=$('perfSales')?.value||'All';
  const today=new Date().toISOString().split('T')[0];
  const thisYear=today.slice(0,4);

  // Filter users
  let visUsers=CU.role==='supervisor'?users.filter(u=>u.supervisorId===CU.id):users;
  if(supF!=='All') visUsers=visUsers.filter(u=>u.supervisorId===Number(supF));
  if(salF!=='All') visUsers=visUsers.filter(u=>u.username===salF);

  // Filter leads by date
  const filteredLeads=allLeads.filter(l=>{
    if(mon!=='All'&&!l.date.startsWith(mon))return false;
    if(yr!=='All'&&mon==='All'&&!l.date.startsWith(yr))return false;
    return true;
  });

  const body=$('perfBody');if(!body)return;
  if(!visUsers.length){body.innerHTML=`<div class="empty" style="padding:40px 20px"><div class="empty-i">📈</div><div class="empty-t">No sales people found</div></div>`;return}

  // Summary row
  const allT=filteredLeads.filter(l=>visUsers.some(u=>u.username===l.createdBy)).length;
  const allHot=filteredLeads.filter(l=>l.status==='Hot'&&visUsers.some(u=>u.username===l.createdBy)).length;
  const allSPK=filteredLeads.filter(l=>l.spkSection&&visUsers.some(u=>u.username===l.createdBy)).length;
  const allDO=filteredLeads.filter(l=>l.doSection&&visUsers.some(u=>u.username===l.createdBy)).length;
  const yearSPK=allLeads.filter(l=>l.spkSection&&l.date.startsWith(thisYear)&&visUsers.some(u=>u.username===l.createdBy)).length;

  let h=`<div class="perf-card" style="margin-bottom:16px;border-left:3px solid var(--acc)">
    <div style="font-size:12px;font-weight:700;color:var(--t1);margin-bottom:10px">Overall Summary — ${visUsers.length} sales person${visUsers.length>1?'s':''}</div>
    <div class="perf-grid">
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--acc)">${allT}</div><div class="perf-stat-l">Total</div></div>
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--red)">${allHot}</div><div class="perf-stat-l">Hot</div></div>
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--grn)">${allSPK}</div><div class="perf-stat-l">SPK</div></div>
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--pur)">${allDO}</div><div class="perf-stat-l">DO</div></div>
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--cyn)">${yearSPK}</div><div class="perf-stat-l">SPK ${thisYear}</div></div>
      <div class="perf-stat"><div class="perf-stat-v" style="color:var(--t2)">${visUsers.length}</div><div class="perf-stat-l">Team</div></div>
    </div>
  </div>`;

  // Per-person cards
  const maxTotal=Math.max(...visUsers.map(u=>filteredLeads.filter(l=>l.createdBy===u.username).length),1);

  visUsers.map(u=>{
    const uLeads=filteredLeads.filter(l=>l.createdBy===u.username);
    const t=uLeads.length;
    const hot=uLeads.filter(l=>l.status==='Hot').length;
    const spk=uLeads.filter(l=>l.spkSection).length;
    const doC=uLeads.filter(l=>l.doSection).length;
    const todayC=allLeads.filter(l=>(l.updatedAt===today&&l.updatedBy===u.username)||(l.createdAt===today&&l.createdBy===u.username&&!l.updatedAt)).length;
    const yrSPK=allLeads.filter(l=>l.spkSection&&l.date.startsWith(thisYear)&&l.createdBy===u.username).length;
    const sup=userById(u.supervisorId);
    return {u,t,hot,spk,doC,todayC,yrSPK,sup};
  }).sort((a,b)=>b.t-a.t).forEach(x=>{
    const low=x.todayC<3;
    h+=`<div class="perf-card">
      <div class="perf-head">
        <div class="perf-av rc-sales">${initials(x.u.fullName)}</div>
        <div style="flex:1;min-width:0">
          <div class="perf-name"><a href="javascript:void(0)" onclick="openSalesDash('${x.u.username}')" style="color:var(--acc);text-decoration:none;cursor:pointer">${x.u.fullName}</a>${low?' <span style="color:var(--red);font-size:9px;font-weight:600">⚠ '+x.todayC+' today</span>':' <span style="color:var(--grn);font-size:9px;font-weight:600">✓ '+x.todayC+' today</span>'}</div>
          <div class="perf-sub">@${x.u.username}${x.sup?' · Sup: '+x.sup.fullName:''}</div>
        </div>
      </div>
      <div class="perf-grid">
        <div class="perf-stat"><div class="perf-stat-v" style="color:var(--acc)">${x.t}</div><div class="perf-stat-l">Total</div></div>
        <div class="perf-stat"><div class="perf-stat-v" style="color:var(--red)">${x.hot}</div><div class="perf-stat-l">Hot</div></div>
        <div class="perf-stat"><div class="perf-stat-v" style="color:var(--grn)">${x.spk}</div><div class="perf-stat-l">SPK</div></div>
        <div class="perf-stat"><div class="perf-stat-v" style="color:var(--pur)">${x.doC}</div><div class="perf-stat-l">DO</div></div>
        <div class="perf-stat"><div class="perf-stat-v" style="color:var(--cyn)">${x.yrSPK}</div><div class="perf-stat-l">SPK ${thisYear}</div></div>
        <div class="perf-stat"><div class="perf-stat-v" style="color:${low?'var(--red)':'var(--t2)'}">${x.todayC}</div><div class="perf-stat-l">Today</div></div>
      </div>
      <div class="perf-bar"><div class="perf-bar-label">Leads</div><div class="perf-bar-track"><div class="perf-bar-fill" style="width:${(x.t/maxTotal)*100}%;background:var(--acc)"></div></div><div class="perf-bar-val">${x.t}</div></div>
    </div>`;
  });

  body.innerHTML=h;
}

/* ═══════════════════════════════════════
   SALES INDIVIDUAL DASHBOARD
   ═══════════════════════════════════════ */
function openSalesDash(username){
  const u=G('al_users').find(x=>x.username===username);if(!u)return;
  const sup=userById(u.supervisorId);
  const allLeads=G('al_leads').filter(l=>l.createdBy===username);
  const sts=G('al_statuses');const srcs=G('al_sources');
  const today=new Date().toISOString().split('T')[0];
  const thisYear=today.slice(0,4);

  const total=allLeads.length;
  const hot=allLeads.filter(l=>l.status==='Hot').length;
  const warm=allLeads.filter(l=>l.status==='Warm').length;
  const cold=allLeads.filter(l=>l.status==='Cold').length;
  const spk=allLeads.filter(l=>l.spkSection).length;
  const doC=allLeads.filter(l=>l.doSection).length;
  const lost=allLeads.filter(l=>l.status==='LOST').length;
  const yearSPK=allLeads.filter(l=>l.spkSection&&l.date.startsWith(thisYear)).length;
  const todayC=G('al_leads').filter(l=>(l.updatedAt===today&&l.updatedBy===username)||(l.createdAt===today&&l.createdBy===username&&!l.updatedAt)).length;
  const fups=allLeads.filter(l=>l.followUp&&l.followUp<=today&&!['SPK','LOST'].includes(l.status)).length;

  PAGE='perf';
  $('pgTitle').textContent=u.fullName+' — Performance';

  let h=`<div style="margin-bottom:14px"><button class="btn btn-s btn-sm" onclick="renderPerf();$('pgTitle').textContent='Sales Performance'">← Back to All Sales</button></div>`;

  // Profile header
  h+=`<div class="perf-card" style="margin-bottom:16px;border-left:3px solid var(--acc)">
    <div class="perf-head" style="margin-bottom:0">
      <div class="perf-av rc-sales" style="width:48px;height:48px;font-size:16px">${initials(u.fullName)}</div>
      <div style="flex:1">
        <div style="font-size:18px;font-weight:800;color:var(--t1)">${u.fullName}</div>
        <div style="font-size:11px;color:var(--t3)">@${u.username} · ${rLabel(u.role)}${sup?' · Supervisor: '+sup.fullName:''}</div>
        <div style="margin-top:4px;font-size:11px">${todayC<3?'<span style="color:var(--red);font-weight:600">⚠ '+todayC+' updates today</span>':'<span style="color:var(--grn);font-weight:600">✓ '+todayC+' updates today</span>'}</div>
      </div>
    </div>
  </div>`;

  // Stat cards
  h+=`<div class="sg" style="grid-template-columns:repeat(4,1fr)">`;
  [{l:'Total Leads',v:total,c:'var(--acc)',bg:'var(--acc-g)'},
   {l:'Hot',v:hot,c:'var(--red)',bg:'var(--red-g)'},
   {l:'SPK',v:spk,c:'var(--grn)',bg:'var(--grn-g)'},
   {l:'DO',v:doC,c:'var(--pur)',bg:'var(--pur-g)'}
  ].forEach(s=>{h+=`<div class="sc"><div class="sc-bar" style="background:${s.c}"></div><div class="sc-icon" style="background:${s.bg}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="${s.c}" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg></div><div class="sc-v" style="color:${s.c}">${s.v}</div><div class="sc-l">${s.l}</div></div>`});
  h+=`</div>`;

  // Secondary stats
  h+=`<div class="perf-grid" style="margin-bottom:16px">
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--org)">${warm}</div><div class="perf-stat-l">Warm</div></div>
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--acc)">${cold}</div><div class="perf-stat-l">Cold</div></div>
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--red)">${lost}</div><div class="perf-stat-l">LOST</div></div>
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--cyn)">${yearSPK}</div><div class="perf-stat-l">SPK ${thisYear}</div></div>
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--org)">${fups}</div><div class="perf-stat-l">Follow Up</div></div>
    <div class="perf-stat"><div class="perf-stat-v" style="color:var(--t2)">${todayC}</div><div class="perf-stat-l">Today</div></div>
  </div>`;

  // Charts: Status + Source
  const sc=sts.map(s=>({s,c:allLeads.filter(l=>l.status===s).length}));const mx=Math.max(...sc.map(x=>x.c),1);
  const srcC2=srcs.map(s=>({s,c:allLeads.filter(l=>l.source===s).length})).filter(x=>x.c>0).sort((a,b)=>b.c-a.c);const mxS=Math.max(...srcC2.map(x=>x.c),1);const srcTotal=srcC2.reduce((a,x)=>a+x.c,0);

  h+=`<div class="chart-row">
    <div class="chart-card"><div class="chart-title">Leads by Status</div><div class="bar-chart">${sc.map(x=>`<div class="bar-col"><div class="bar-v" style="color:${sC(x.s)}">${x.c}</div><div class="bar-f" style="height:${(x.c/mx)*100}px;background:${sC(x.s)}"></div><div class="bar-l">${x.s}</div></div>`).join('')}</div></div>
    <div class="chart-card"><div class="chart-title">Leads by Source <span style="font-weight:400;color:var(--t3)">(${srcTotal} total)</span></div>${srcC2.length?srcC2.map(x=>`<div class="h-bar"><div class="h-bar-label">${x.s}</div><div class="h-bar-track"><div class="h-bar-fill" style="width:${(x.c/mxS)*100}%;background:${srcC(x.s)}"></div></div><div class="h-bar-val">${x.c}</div></div>`).join(''):'<div class="empty-s">No data</div>'}</div>
  </div>`;

  // Monthly trend this year
  const months=[];
  for(let m=0;m<12;m++){
    const key=thisYear+'-'+String(m+1).padStart(2,'0');
    const mn=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][m];
    const cnt=allLeads.filter(l=>l.date&&l.date.startsWith(key)).length;
    const spkCnt=allLeads.filter(l=>l.spkSection&&l.date&&l.date.startsWith(key)).length;
    months.push({mn,cnt,spkCnt});
  }
  const mxM=Math.max(...months.map(m=>m.spkCnt),1);
  h+=`<div class="chart-card" style="margin-bottom:16px"><div class="chart-title">Monthly SPK ${thisYear}</div><div class="bar-chart" style="height:100px">${months.map(m=>`<div class="bar-col"><div class="bar-v" style="color:var(--grn);font-size:8px">${m.spkCnt}</div><div class="bar-f" style="height:${(m.spkCnt/mxM)*100}px;background:var(--grn)"></div><div class="bar-l">${m.mn}</div></div>`).join('')}</div></div>`;

  // Recent leads table
  h+=`<div class="tc"><div class="th"><div class="th-t">Recent Leads</div></div><div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Car</th><th>Status</th><th>Source</th><th>Date</th><th>Follow Up</th></tr></thead><tbody>`;
  allLeads.slice(0,15).forEach(l=>{
    h+=`<tr onclick="openLD(${l.id})" style="cursor:pointer"><td><strong style="font-size:12px">${l.name}</strong><div style="font-size:9px;color:var(--t4)">${l.phone}</div></td><td style="font-size:11px">${l.carType}</td><td><span class="badge" style="background:${sBg(l.status)};color:${sC(l.status)}"><span class="bdot" style="background:${sC(l.status)}"></span>${l.status}</span></td><td><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:9px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></td><td style="font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--t3)">${l.date}</td><td style="font-size:10px">${fuCountdown(l.followUp)}</td></tr>`;
  });
  h+=`</tbody></table></div></div>`;

  $('pgC').innerHTML=h;
}

function expPerfCSV(){
  const allLeads=G('al_leads');
  const users=G('al_users').filter(u=>u.role==='sales'&&u.active);
  const visUsers=CU.role==='supervisor'?users.filter(u=>u.supervisorId===CU.id):users;
  const today=new Date().toISOString().split('T')[0];
  const esc=v=>{const s=String(v||'');return s.includes(',')?'"'+s+'"':s};
  const h=['Sales Person','Username','Supervisor','Total Leads','Hot','SPK','DO','Conversion Rate','Daily Updates'];
  let csv=h.join(',')+'\n';
  visUsers.forEach(u=>{
    const uLeads=allLeads.filter(l=>l.createdBy===u.username);
    const t=uLeads.length,hot=uLeads.filter(l=>l.status==='Hot').length;
    const spk=uLeads.filter(l=>l.spkSection).length,doC=uLeads.filter(l=>l.doSection).length;
    const todayC=allLeads.filter(l=>(l.updatedAt===today&&l.updatedBy===u.username)||(l.createdAt===today&&l.createdBy===u.username&&!l.updatedAt)).length;
    const conv=t?Math.round((spk/t)*100):0;
    const sup=userById(u.supervisorId);
    csv+=[esc(u.fullName),u.username,esc(sup?sup.fullName:''),t,hot,spk,doC,conv+'%',todayC].join(',')+'\n';
  });
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=`CheryBatam_Performance_${CU.role}_${new Date().toISOString().split('T')[0]}.csv`;
  document.body.appendChild(a);a.click();document.body.removeChild(a);
  toast('Performance CSV exported');
}

