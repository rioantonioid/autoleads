function addT(k){const i=$('nt_'+k);const v=i.value.trim();if(!v)return;let a=G(k);if(a.includes(v)){toast('Already exists');return}a.push(v);S(k,a);toast('Added');renderSets()}
function rmT(k,v){let a=G(k).filter(x=>x!==v);if(!a.length){toast('Need at least one');return}S(k,a);
  if(k==='al_statuses'){let cc=G('al_custom_colors')||{};delete cc[v];S('al_custom_colors',cc);delete SC_MAP[v]}
  if(k==='al_sources'){let sc=G('al_source_colors')||{};delete sc[v];S('al_source_colors',sc);delete SRC_MAP[v]}
  toast('Removed');renderSets()}

