const DEFAULT_STOCK_COLORS={'White':'#F8FAFC','Black':'#1E293B','Silver':'#CBD5E1','Grey':'#6B7280','Red':'#EF4444','Blue':'#3B82F6','Green':'#22C55E','Brown':'#92400E','Gold':'#D97706','Orange':'#F97316','Yellow':'#EAB308','Purple':'#A855F7','Navy':'#1E3A5F','Maroon':'#7F1D1D','Beige':'#D2B48C'};
function getStockColors(){return G('al_stock_colors')||DEFAULT_STOCK_COLORS}
function isDarkHex(hex){if(!hex)return false;const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);return(r*299+g*587+b*114)/1000<100}
let stkSearch='';

function renderStock(){
  const canManage=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const stock=G('al_stock')||[];
  const stockMeta=G('al_stock_meta')||{};
  const lastUpdate=stockMeta.updatedAt?stockMeta.updatedAt:'Never';
  const updatedBy=stockMeta.updatedBy?userByUn(stockMeta.updatedBy):null;

  $('topA').innerHTML=canManage?`<button class="btn btn-p btn-sm" onclick="openStockForm()">+ Add Stock</button>`:'';

  // Summary counts
  const totalQty=stock.reduce((a,s)=>a+(s.qty||1),0);
  const ready=stock.filter(s=>s.availability==='Ready').reduce((a,s)=>a+(s.qty||1),0);
  const otw=stock.filter(s=>s.availability==='OTW').reduce((a,s)=>a+(s.qty||1),0);
  const models=[...new Set(stock.map(s=>s.model))];

  let h=`<div class="stk-count">
    <div class="stk-count-item"><div class="stk-count-v" style="color:var(--acc)">${totalQty}</div><div class="stk-count-l">Total Units</div></div>
    <div class="stk-count-item"><div class="stk-count-v" style="color:var(--grn)">${ready}</div><div class="stk-count-l">Ready</div></div>
    <div class="stk-count-item"><div class="stk-count-v" style="color:var(--org)">${otw}</div><div class="stk-count-l">On The Way</div></div>
    <div class="stk-count-item"><div class="stk-count-v" style="color:var(--pur)">${models.length}</div><div class="stk-count-l">Models</div></div>
  </div>`;

  // Update info bar
  h+=`<div class="stk-bar">
    <div style="flex:1;min-width:0">
      <div class="stk-bar-info">🕐 Last updated: <strong>${lastUpdate!=='Never'?lastUpdate:'Never'}</strong>${updatedBy?' by <strong>'+updatedBy.fullName+'</strong>':''}</div>
    </div>
    <input class="fi" style="max-width:220px;font-size:11px" placeholder="🔍 Search model, type, year, color..." value="${stkSearch}" oninput="stkSearch=this.value;renderStockCards()">
    <select class="fd" id="stkFilter" onchange="renderStockCards()" style="max-width:150px">
      <option value="All">All Status</option>
      <option value="Ready">✅ Ready</option>
      <option value="OTW">🚚 OTW</option>
    </select>
    <select class="fd" id="stkModelFilter" onchange="renderStockCards()" style="max-width:160px">
      <option value="All">All Models</option>
      ${models.sort().map(m=>`<option value="${m}">${m}</option>`).join('')}
    </select>
  </div>`;

  h+=`<div id="stkBody"></div>`;
  $('pgC').innerHTML=h;
  renderStockCards();
}

function renderStockCards(){
  let stock=G('al_stock')||[];
  const canManage=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const filter=$('stkFilter')?.value||'All';
  const modelFilter=$('stkModelFilter')?.value||'All';

  if(filter!=='All') stock=stock.filter(s=>s.availability===filter);
  if(modelFilter!=='All') stock=stock.filter(s=>s.model===modelFilter);
  if(stkSearch){
    const q=stkSearch.toLowerCase();
    stock=stock.filter(s=>(s.model||'').toLowerCase().includes(q)||(s.type||'').toLowerCase().includes(q)||(s.year||'').toString().includes(q)||(s.color||'').toLowerCase().includes(q));
  }

  if(!stock.length){
    $('stkBody').innerHTML=`<div class="empty" style="padding:40px"><div class="empty-i">📦</div><div class="empty-t">No stock found</div><div class="empty-s">${stkSearch||filter!=='All'||modelFilter!=='All'?'Try adjusting filters':'Stock inventory will appear here'}</div></div>`;
    return;
  }

  stock.sort((a,b)=>(a.model||'').localeCompare(b.model)||(a.type||'').localeCompare(b.type)||(a.color||'').localeCompare(b.color));

  let h=`<div class="tc" style="margin:0"><div style="overflow-x:auto"><table>
    <thead><tr><th style="width:30px">#</th><th>Model</th><th>Type</th><th>Year</th><th>Color</th><th>Status</th><th style="text-align:center">Qty</th>${canManage?'<th style="width:60px"></th>':''}</tr></thead><tbody>`;
  stock.forEach((s,i)=>{
    const colorHex=getStockColors()[s.color]||'#CBD5E1';
    const isDark=isDarkHex(colorHex);
    const qty=s.qty||1;
    h+=`<tr>
      <td style="font-size:10px;color:var(--t4)">${i+1}</td>
      <td style="font-weight:700">${s.model||'—'}</td>
      <td>${s.type||'—'}</td>
      <td>${s.year||'—'}</td>
      <td><div style="display:flex;align-items:center;gap:6px"><div style="width:14px;height:14px;border-radius:50%;background:${colorHex};border:2px solid ${isDark?colorHex:'var(--bdr)'};flex-shrink:0"></div>${s.color||'—'}</div></td>
      <td><span class="stk-badge ${s.availability==='Ready'?'ready':'otw'}">${s.availability==='Ready'?'✅ Ready':'🚚 OTW'}</span></td>
      <td style="text-align:center;font-weight:800;font-size:14px">${qty}</td>
      ${canManage?`<td><div style="display:flex;gap:3px"><button class="abtn" onclick="openStockForm(${s.id})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button><button class="abtn del" onclick="delStock(${s.id})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button></div></td>`:''}</tr>`;
  });
  h+=`</tbody></table></div></div>`;
  $('stkBody').innerHTML=h;
}

function openStockForm(id){
  const canManage=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  if(!canManage) return;
  const stock=G('al_stock')||[];
  const s=id?stock.find(x=>x.id===id):null;

  const carTypes=G('al_cartypes')||[];
  const colorOpts=Object.keys(getStockColors());
  const selColor=s?s.color:'White';
  const selModel=s?s.model:'';
  const curYear=new Date().getFullYear();
  const years=[];for(let y=curYear+1;y>=curYear-5;y--) years.push(y);

  const modelBtns=carTypes.map(m=>{
    const sel=selModel===m;
    return `<button type="button" class="btn btn-sm stkModelBtn" data-model="${m}" onclick="pickStkModel(this)" style="padding:8px 12px;font-size:11px;white-space:nowrap;${sel?'background:var(--acc);color:#fff;border-color:var(--acc)':''}">${m}</button>`;
  }).join('');

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:500px">
    <div class="md-h"><span class="md-t">${s?'✏️ Edit Stock':'📦 Add Stock'}</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div class="fg"><label class="fl">Model *</label>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;max-height:200px;overflow-y:auto;padding:4px 0">${modelBtns}</div>
        <input type="hidden" id="stkModel" value="${selModel}">
      </div>
      <div class="fr2">
        <div class="fg"><label class="fl">Year *</label>
          <select class="fi" id="stkYear">${years.map(y=>`<option value="${y}" ${s&&s.year==y?'selected':(!s&&y===curYear?'selected':'')}>${y}</option>`).join('')}</select>
        </div>
        <div class="fg"><label class="fl">Type / Variant</label><input class="fi" id="stkType" value="${s?s.type||'':''}" placeholder="e.g. Luxury, Premium"></div>
      </div>
      <div class="fg"><label class="fl">Qty *</label><input class="fi" id="stkQty" type="number" min="1" value="${s?s.qty||1:1}" style="max-width:100px"></div>
      <div class="fg"><label class="fl">Color *</label>
        <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px" id="stkColorPicker">
          ${colorOpts.map(c=>{const hex=getStockColors()[c];const isDark=isDarkHex(hex);return `<div style="display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer" onclick="pickStkColor('${c}')"><div class="stk-color-dot${selColor===c?' sel':''}" style="background:${hex};width:28px;height:28px;${isDark?'border-color:'+hex:''}${selColor===c?';box-shadow:0 0 0 3px var(--acc);border-color:var(--acc)':''}"></div><span style="font-size:7px;color:var(--t4)">${c}</span></div>`}).join('')}
        </div>
        <input type="hidden" id="stkColor" value="${selColor}">
      </div>
      <div class="fg"><label class="fl">Availability *</label>
        <div style="display:flex;gap:8px;margin-top:4px">
          <button class="btn btn-sm stkAvailBtn" data-val="Ready" onclick="pickStkAvail('Ready')" style="flex:1;padding:10px;font-size:12px;${(!s||s.availability==='Ready')?'background:var(--grn);color:#fff;border-color:var(--grn)':''}">✅ Ready</button>
          <button class="btn btn-sm stkAvailBtn" data-val="OTW" onclick="pickStkAvail('OTW')" style="flex:1;padding:10px;font-size:12px;${s&&s.availability==='OTW'?'background:var(--org);color:#fff;border-color:var(--org)':''}">🚚 On The Way</button>
        </div>
        <input type="hidden" id="stkAvail" value="${s?s.availability:'Ready'}">
      </div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-p" onclick="saveStock(${id||0})">${s?'Update':'Add'}</button></div>
  </div></div>`;
}

function pickStkModel(btn){
  document.querySelectorAll('.stkModelBtn').forEach(b=>{b.style.background='';b.style.color='';b.style.borderColor=''});
  btn.style.background='var(--acc)';btn.style.color='#fff';btn.style.borderColor='var(--acc)';
  $('stkModel').value=btn.dataset.model;
}

function pickStkColor(color){
  $('stkColor').value=color;
  document.querySelectorAll('#stkColorPicker .stk-color-dot').forEach(d=>{
    const c=d.parentElement.querySelector('span').textContent;
    if(c===color){d.style.boxShadow='0 0 0 3px var(--acc)';d.style.borderColor='var(--acc)'}
    else{d.style.boxShadow='';d.style.borderColor=''}
  });
}

function pickStkAvail(val){
  $('stkAvail').value=val;
  document.querySelectorAll('.stkAvailBtn').forEach(b=>{
    const v=b.dataset.val;const sel=v===val;
    if(v==='Ready') b.style.cssText=`flex:1;padding:10px;font-size:12px;${sel?'background:var(--grn);color:#fff;border-color:var(--grn)':''}`;
    else b.style.cssText=`flex:1;padding:10px;font-size:12px;${sel?'background:var(--org);color:#fff;border-color:var(--org)':''}`;
  });
}

function saveStock(id){
  const model=$('stkModel').value.trim();
  const type=$('stkType').value.trim();
  const year=$('stkYear').value;
  const color=$('stkColor').value;
  const availability=$('stkAvail').value;
  const qty=Math.max(1,parseInt($('stkQty').value)||1);
  if(!model){toast('Select a model');return}
  if(!color){toast('Color is required');return}

  let stock=G('al_stock')||[];
  const now=localDate(new Date());

  if(id){
    // Editing — check if the edited values now match another existing row
    const match=stock.find(s=>s.id!==id&&s.model===model&&s.type===type&&s.year===year&&s.color===color&&s.availability===availability);
    if(match){
      // Merge into existing row
      match.qty=(match.qty||1)+qty;
      stock=stock.filter(s=>s.id!==id);
      toast(`Merged — ${model} ${color} now has ${match.qty} units`);
    }else{
      stock=stock.map(s=>s.id===id?{...s,model,type,year,color,availability,qty}:s);
      toast('Stock updated');
    }
  }else{
    // Adding new — check if same combo exists
    const match=stock.find(s=>s.model===model&&s.type===type&&s.year===year&&s.color===color&&s.availability===availability);
    if(match){
      match.qty=(match.qty||1)+qty;
      toast(`+${qty} added — ${model} ${color} now has ${match.qty} units`);
    }else{
      stock.push({id:Date.now(),model,type,year,color,availability,qty});
      toast('Stock added');
    }
  }
  S('al_stock',stock);
  S('al_stock_meta',{updatedAt:now+' '+new Date().toTimeString().slice(0,5),updatedBy:CU.username});
  closeMd();renderStock();
}

function delStock(id){
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:360px">
    <div class="md-h"><span class="md-t">🗑 Delete Stock</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b"><div style="text-align:center;padding:10px 0;color:var(--t2);font-size:13px">Remove this vehicle from stock?</div></div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-d" onclick="confirmDelStock(${id})">Delete</button></div>
  </div></div>`;
}

function confirmDelStock(id){
  let stock=G('al_stock')||[];
  stock=stock.filter(s=>s.id!==id);
  S('al_stock',stock);
  S('al_stock_meta',{updatedAt:localDate(new Date())+' '+new Date().toTimeString().slice(0,5),updatedBy:CU.username});
  closeMd();toast('Stock removed');renderStock();
}

/* ═══════════════════════════════════════
   ACTIVITY / EVENTS
   ═══════════════════════════════════════ */
const EVT_COLORS=['#3B82F6','#EF4444','#22C55E','#F59E0B','#A78BFA','#EC4899','#06B6D4','#F97316'];
const MIN_STAFF=2;

function getEvtStaffing(evtId){
  const events=G('al_events')||[];
  const e=events.find(x=>x.id===evtId);if(!e) return null;
  const schedules=G('al_schedules')||[];
  const result={event:e,days:[],totalShort:0,minStaff:99};
  const start=new Date(e.startDate);const end=new Date(e.endDate);
  for(let d=new Date(start);d<=end;d.setDate(d.getDate()+1)){
    const ds=localDate(d);
    const assigned=schedules.filter(s=>s.date===ds&&s.eventId===evtId);
    const names=assigned.map(s=>{const u=userByUn(s.username);return u?u.fullName:s.username});
    const count=assigned.length;
    const short=count<MIN_STAFF;
    if(short) result.totalShort++;
    if(count<result.minStaff) result.minStaff=count;
    result.days.push({date:ds,count,names,short});
  }
  return result;
}

function getEvtWarnings(){
  const events=G('al_events')||[];
  const active=events.filter(e=>e.status!=='suggested');
  const warnings=[];
  active.forEach(e=>{
    const info=getEvtStaffing(e.id);
    if(info&&info.totalShort>0) warnings.push(info);
  });
  return warnings;
}
let evtMonth=new Date().getMonth();
let evtYear=new Date().getFullYear();

function renderEvents(){
  const canCreate=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const canSuggest=CU.role==='supervisor';
  const monthNames=['January','February','March','April','May','June','July','August','September','October','November','December'];

  $('topA').innerHTML=(canCreate||canSuggest)?`<button class="btn btn-p btn-sm" onclick="openEvtForm()">${canSuggest?'💡 Suggest Activity':'+ New Activity'}</button>`:'';

  const events=G('al_events')||[];
  const monthKey=evtYear+'-'+String(evtMonth+1).padStart(2,'0');

  // Filter events that overlap this month
  const firstOfMonth=monthKey+'-01';
  const lastOfMonth=monthKey+'-'+new Date(evtYear,evtMonth+1,0).getDate();
  const monthEvents=events.filter(e=>{
    return e.startDate<=lastOfMonth&&e.endDate>=firstOfMonth;
  });

  let h=`<div class="evt-header">
    <div class="sch-nav">
      <button class="sch-nav-btn" onclick="evtPrev()">◀</button>
      <div class="sch-month">${monthNames[evtMonth]} ${evtYear}</div>
      <button class="sch-nav-btn" onclick="evtNext()">▶</button>
      <button class="sch-nav-btn" onclick="evtToday()" style="margin-left:8px">Today</button>
    </div>
  </div>`;

  // Calendar grid
  h+=buildEvtCal(monthEvents);

  // List view below calendar
  const today=localDate(new Date());
  const sorted=[...monthEvents].sort((a,b)=>a.startDate.localeCompare(b.startDate));
  const activeEvts=sorted.filter(e=>e.status!=='suggested');
  const suggestedEvts=sorted.filter(e=>e.status==='suggested');

  if(activeEvts.length){
    h+=`<div style="font-size:13px;font-weight:700;color:var(--t1);margin:16px 0 8px">📋 Events This Month</div>`;
    activeEvts.forEach(e=>{ h+=buildEvtCard(e,today,canCreate); });
  }

  if(suggestedEvts.length&&(canCreate||canSuggest)){
    h+=`<div style="font-size:13px;font-weight:700;color:var(--org);margin:16px 0 8px">💡 Suggested by Supervisors</div>`;
    suggestedEvts.forEach(e=>{ h+=buildEvtCard(e,today,canCreate); });
  }

  if(!sorted.length){
    h+=`<div class="empty" style="padding:40px 20px"><div class="empty-i">🎯</div><div class="empty-t">No activities this month</div><div class="empty-s">${canCreate?'Click + New Activity to create one':'Activities will appear here when managers create them'}</div></div>`;
  }

  $('pgC').innerHTML=h;
}

function buildEvtCal(monthEvents){
  const dayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const firstDay=new Date(evtYear,evtMonth,1);
  const lastDay=new Date(evtYear,evtMonth+1,0);
  const daysInMonth=lastDay.getDate();
  const today=localDate(new Date());

  let startDow=firstDay.getDay();
  startDow=startDow===0?6:startDow-1;

  let h=`<div class="evt-cal">`;
  dayNames.forEach(d=>{h+=`<div class="evt-cal-hdr">${d}</div>`});

  // Padding days before month
  for(let i=0;i<startDow;i++){
    const pd=new Date(firstDay);pd.setDate(pd.getDate()-(startDow-i));
    h+=`<div class="evt-cal-day other"><div class="evt-cal-day-num">${pd.getDate()}</div></div>`;
  }

  // Actual days
  for(let d=1;d<=daysInMonth;d++){
    const ds=evtYear+'-'+String(evtMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const isToday=ds===today;
    const dayEvts=monthEvents.filter(e=>ds>=e.startDate&&ds<=e.endDate&&e.status!=='suggested');

    h+=`<div class="evt-cal-day${isToday?' today':''}">`;
    h+=`<div class="evt-cal-day-num">${d}</div>`;
    dayEvts.slice(0,3).forEach(e=>{
      const color=e.color||EVT_COLORS[0];
      h+=`<div class="evt-cal-dot" style="background:${color}20;color:${color}" onclick="openEvtDetail(${e.id})" title="${e.name}">${e.name}</div>`;
    });
    if(dayEvts.length>3) h+=`<div style="font-size:6px;color:var(--t4);text-align:center">+${dayEvts.length-3} more</div>`;
    h+=`</div>`;
  }

  // Padding days after month
  const totalCells=startDow+daysInMonth;
  const remaining=totalCells%7===0?0:7-(totalCells%7);
  for(let i=1;i<=remaining;i++){
    h+=`<div class="evt-cal-day other"><div class="evt-cal-day-num">${i}</div></div>`;
  }
  h+=`</div>`;
  return h;
}

function buildEvtCard(e,today,canEdit){
  const color=e.color||EVT_COLORS[0];
  const isSuggested=e.status==='suggested';
  const startD=new Date(e.startDate);
  const endD=new Date(e.endDate);
  const days=Math.round((endD-startD)/86400000)+1;
  const isActive=e.startDate<=today&&e.endDate>=today;
  const isUpcoming=e.startDate>today;
  const isPast=e.endDate<today;
  const statusLabel=isSuggested?'suggested':isActive?'active':isUpcoming?'upcoming':'completed';
  const statusText=isSuggested?'💡 Suggested':isActive?'🟢 Active Now':isUpcoming?'🔵 Upcoming':'✅ Completed';
  const createdByUser=userByUn(e.createdBy);

  let acts='';
  if(canEdit){
    acts+=`<button class="abtn" onclick="openEvtForm(${e.id})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>`;
    acts+=`<button class="abtn del" onclick="delEvt(${e.id})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>`;
    if(isSuggested) acts=`<button class="btn btn-p btn-sm" onclick="approveEvt(${e.id})" style="font-size:9px;padding:3px 8px">✓ Approve</button>`+acts;
  }

  // Staffing check (skip for suggested/completed)
  let staffHtml='';
  if(!isSuggested&&!isPast){
    const info=getEvtStaffing(e.id);
    if(info){
      if(info.totalShort>0){
        staffHtml+=`<div style="margin-top:8px;padding:8px;border-radius:var(--r);background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.15)">
          <div style="font-size:10px;font-weight:700;color:var(--red);margin-bottom:4px">⚠ Understaffed — need ${MIN_STAFF}+ sales per day</div>
          <div style="display:flex;flex-wrap:wrap;gap:3px">${info.days.map(d=>{
            const dayName=new Date(d.date).toLocaleDateString('en',{weekday:'short',day:'numeric'});
            return d.short?`<span style="font-size:8px;padding:2px 6px;border-radius:4px;background:var(--red-g);color:var(--red);font-weight:600">${dayName}: ${d.count}/${MIN_STAFF}</span>`
              :`<span style="font-size:8px;padding:2px 6px;border-radius:4px;background:var(--grn-g);color:var(--grn);font-weight:600">${dayName}: ${d.count}✓</span>`;
          }).join('')}</div>
        </div>`;
      }else{
        staffHtml+=`<div style="margin-top:6px;font-size:9px;color:var(--grn);font-weight:600">✓ All days staffed (${MIN_STAFF}+ sales assigned)</div>`;
      }
    }
  }

  return `<div class="evt-card${isSuggested?' suggested':''}" style="border-left-color:${color}">
    <div class="evt-card-head">
      <div style="flex:1;min-width:0">
        <div class="evt-card-name">${e.name}</div>
        ${e.location?`<div class="evt-card-loc">📍 ${e.location}</div>`:''}
        <div class="evt-card-dates">📅 ${e.startDate} → ${e.endDate} <span style="font-size:10px;color:var(--t4);font-weight:400">(${days} day${days>1?'s':''})</span></div>
        <div class="evt-card-meta">
          <span class="evt-status ${statusLabel}">${statusText}</span>
          <span>by ${createdByUser?createdByUser.fullName:e.createdBy}</span>
        </div>
        ${staffHtml}
      </div>
      <div class="evt-card-acts">${acts}</div>
    </div>
  </div>`;
}

function openEvtForm(id){
  const canCreate=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const canSuggest=CU.role==='supervisor';
  if(!canCreate&&!canSuggest) return;

  const events=G('al_events')||[];
  const e=id?events.find(x=>x.id===id):null;
  const today=localDate(new Date());
  const isEdit=!!e;

  const colorBtns=EVT_COLORS.map((c,i)=>{
    const sel=e?e.color===c:i===0;
    return `<div class="evt-color-opt${sel?' sel':''}" style="background:${c}" onclick="pickEvtColor(this,'${c}')"></div>`;
  }).join('');

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:460px">
    <div class="md-h"><span class="md-t">${isEdit?'✏️ Edit Activity':canSuggest?'💡 Suggest Activity':'🎯 New Activity'}</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div class="fg"><label class="fl">Event Name *</label><input class="fi" id="evtName" value="${e?e.name:''}" placeholder="e.g. Mall Exhibition Nagoya Hill"></div>
      <div class="fg"><label class="fl">Location / Venue</label><input class="fi" id="evtLoc" value="${e?e.location||'':''}" placeholder="e.g. Nagoya Hill Mall, Lt. 1"></div>
      <div class="fr2">
        <div class="fg"><label class="fl">Start Date *</label><input class="fi" id="evtStart" type="date" value="${e?e.startDate:today}"></div>
        <div class="fg"><label class="fl">End Date *</label><input class="fi" id="evtEnd" type="date" value="${e?e.endDate:today}"></div>
      </div>
      <div class="fg"><label class="fl">Color</label><div class="evt-colors">${colorBtns}</div><input type="hidden" id="evtColor" value="${e?e.color||EVT_COLORS[0]:EVT_COLORS[0]}"></div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-p" onclick="saveEvt(${id||0})">${isEdit?'Update':canSuggest?'Suggest':'Create'}</button></div>
  </div></div>`;
}

function pickEvtColor(el,color){
  document.querySelectorAll('.evt-color-opt').forEach(e=>e.classList.remove('sel'));
  el.classList.add('sel');
  $('evtColor').value=color;
}

function saveEvt(id){
  const name=$('evtName').value.trim();
  const location=$('evtLoc').value.trim();
  const startDate=$('evtStart').value;
  const endDate=$('evtEnd').value;
  const color=$('evtColor').value;
  if(!name){toast('Event name required');return}
  if(!startDate||!endDate){toast('Start and end dates required');return}
  if(endDate<startDate){toast('End date must be after start date');return}

  const canCreate=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  const now=localDate(new Date());
  let events=G('al_events')||[];

  if(id){
    events=events.map(e=>e.id===id?{...e,name,location,startDate,endDate,color,updatedBy:CU.username,updatedAt:now}:e);
    toast('Activity updated');
  }else{
    events.push({
      id:Date.now(),name,location,startDate,endDate,color,
      status:canCreate?'active':'suggested',
      createdBy:CU.username,createdAt:now
    });
    toast(canCreate?'Activity created':'Suggestion submitted');
  }
  S('al_events',events);
  closeMd();renderEvents();
}

function delEvt(id){
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:360px">
    <div class="md-h"><span class="md-t">🗑 Delete Activity</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b"><div style="text-align:center;padding:10px 0;color:var(--t2);font-size:13px">Are you sure you want to delete this activity?</div></div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-d" onclick="confirmDelEvt(${id})">Delete</button></div>
  </div></div>`;
}

function confirmDelEvt(id){
  let events=G('al_events')||[];
  events=events.filter(e=>e.id!==id);
  S('al_events',events);
  closeMd();toast('Activity deleted');renderEvents();
}

function approveEvt(id){
  let events=G('al_events')||[];
  events=events.map(e=>e.id===id?{...e,status:'active',approvedBy:CU.username,approvedAt:localDate(new Date())}:e);
  S('al_events',events);
  toast('Activity approved');renderEvents();
}

function openEvtDetail(id){
  const events=G('al_events')||[];
  const e=events.find(x=>x.id===id);if(!e) return;
  const canEdit=['director','admin','branch_manager','sales_manager','supervisor'].includes(CU.role);
  const days=Math.round((new Date(e.endDate)-new Date(e.startDate))/86400000)+1;
  const createdByUser=userByUn(e.createdBy);
  const color=e.color||EVT_COLORS[0];

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:420px">
    <div class="md-h"><span class="md-t">🎯 Activity Detail</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="border-left:4px solid ${color};padding-left:12px;margin-bottom:12px">
        <div style="font-size:16px;font-weight:700;color:var(--t1)">${e.name}</div>
        ${e.location?`<div style="font-size:12px;color:var(--t3);margin-top:4px">📍 ${e.location}</div>`:''}
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
        <div><div style="font-size:9px;color:var(--t4);text-transform:uppercase;letter-spacing:.5px">Start Date</div><div style="font-size:13px;font-weight:700;color:var(--acc);font-family:'JetBrains Mono',monospace;margin-top:2px">${e.startDate}</div></div>
        <div><div style="font-size:9px;color:var(--t4);text-transform:uppercase;letter-spacing:.5px">End Date</div><div style="font-size:13px;font-weight:700;color:var(--acc);font-family:'JetBrains Mono',monospace;margin-top:2px">${e.endDate}</div></div>
      </div>
      <div style="font-size:11px;color:var(--t3);padding-top:8px;border-top:1px solid var(--bdr)">Duration: ${days} day${days>1?'s':''} · Created by ${createdByUser?createdByUser.fullName:e.createdBy} on ${e.createdAt}</div>
    </div>
    <div class="md-f">${canEdit?`<button class="btn btn-s" onclick="closeMd();openEvtForm(${e.id})">✏️ Edit</button>`:''}<button class="btn btn-p" onclick="closeMd()">Close</button></div>
  </div></div>`;
}

function evtPrev(){evtMonth--;if(evtMonth<0){evtMonth=11;evtYear--}renderEvents()}
function evtNext(){evtMonth++;if(evtMonth>11){evtMonth=0;evtYear++}renderEvents()}
function evtToday(){const t=new Date();evtYear=t.getFullYear();evtMonth=t.getMonth();renderEvents()}

/* ═══════════════════════════════════════
   SALES SCHEDULE
   ═══════════════════════════════════════ */
const BASE_SHIFTS=[
  {id:'morning',label:'Morning',icon:'☀️',color:'#1D4ED8'},
  {id:'afternoon',label:'Afternoon',icon:'🌅',color:'#92400E'},
  {id:'off',label:'Off',icon:'😴',color:'#94A3B8'}
];

function getShiftOptions(dateStr){
  const events=G('al_events')||[];
  const dayEvts=events.filter(e=>e.status!=='suggested'&&dateStr>=e.startDate&&dateStr<=e.endDate);
  return [...dayEvts.map(e=>({id:'evt_'+e.id,label:e.name,icon:'🎯',color:e.color||'#7C3AED',isEvent:true})),...BASE_SHIFTS];
}

function getShiftInfo(shiftId){
  if(!shiftId) return null;
  const base=BASE_SHIFTS.find(s=>s.id===shiftId);
  if(base) return base;
  if(shiftId.startsWith('evt_')){
    const evtId=Number(shiftId.slice(4));
    const events=G('al_events')||[];
    const evt=events.find(e=>e.id===evtId);
    if(evt) return {id:shiftId,label:evt.name,icon:'🎯',color:evt.color||'#7C3AED',isEvent:true};
  }
  return null;
}

function shiftHtml(entry,big){
  if(!entry) return '';
  const base=BASE_SHIFTS.find(s=>s.id===entry.shift);
  if(!base) return '';
  const c=base.color;
  const sz=big?'padding:6px;font-size:12px':'';
  let h=`<div class="sch-shift" style="background:${c}20;color:${c};${sz}">${base.icon} ${base.label}</div>`;
  if(entry.eventId){
    const events=G('al_events')||[];
    const evt=events.find(e=>e.id===entry.eventId);
    if(evt){
      const ec=evt.color||'#7C3AED';
      h+=`<div style="font-size:${big?'10':'9'}px;color:${ec};font-weight:700;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">🎯 ${evt.name}</div>`;
    }
  }
  return h;
}

let schYear=new Date().getFullYear();
let schMonth=new Date().getMonth();
let schView='month';
let schWeekStart=null;

function renderSchedule(){
  $('topA').innerHTML='';
  const canEdit=['director','admin','branch_manager','sales_manager','supervisor'].includes(CU.role);
  const allSales=G('al_users').filter(u=>u.role==='sales'&&u.active);
  const sups=G('al_users').filter(u=>u.role==='supervisor'&&u.active);
  const monthNames=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const dayNames=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  // Events this month for activity filter
  const mk=schYear+'-'+String(schMonth+1).padStart(2,'0');
  const lm=mk+'-'+new Date(schYear,schMonth+1,0).getDate();
  const ae=(G('al_events')||[]).filter(e=>e.status!=='suggested'&&e.endDate>=mk+'-01'&&e.startDate<=lm);
  const evtF=window._schEvtFilter||'All';

  // Activity filter dropdown
  let actFilterHtml='';
  if(ae.length&&CU.role!=='sales'){
    actFilterHtml=`<select class="fd" id="schEvt" onchange="onSchEvtChange()" style="max-width:200px"><option value="All">All Schedule</option>${ae.map(e=>{const c=e.color||'#7C3AED';return `<option value="${e.id}" ${String(evtF)===String(e.id)?'selected':''}>🎯 ${e.name}</option>`}).join('')}</select>`;
  }

  // Role-based user list
  let users;
  let filterHtml='';
  if(CU.role==='sales'){
    users=allSales.filter(u=>u.username===CU.username);
  }else{
    // SPV, SM+, BM, Director, Admin — all see everyone with supervisor filter
    users=allSales;
    filterHtml=`<select class="fd" id="schSup" onchange="renderSchedule()"><option value="All">All Supervisors</option>${sups.map(s=>`<option value="${s.id}">${s.fullName}</option>`).join('')}</select>`;
  }

  const solo=CU.role==='sales'&&users.length===1;

  let h=`<div class="sch-header"><div class="sch-nav"><button class="sch-nav-btn" onclick="schPrev()">◀</button><div class="sch-month">${monthNames[schMonth]} ${schYear}</div><button class="sch-nav-btn" onclick="schNext()">▶</button><button class="sch-nav-btn" onclick="schToday()" style="margin-left:8px">Today</button></div><div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap"><div class="sch-view-toggle"><button class="sch-view-btn ${schView==='month'?'act':''}" onclick="schView='month';window._schEvtFilter='All';renderSchedule()">Month</button><button class="sch-view-btn ${schView==='week'?'act':''}" onclick="schSetWeekView()">Week</button></div>${actFilterHtml}${filterHtml}</div></div>`;

  // Activity-focused view or normal view
  if(evtF!=='All'){
    const selEvt=ae.find(e=>e.id===Number(evtF));
    if(selEvt) h+=buildEvtScheduleView(selEvt,users,canEdit,dayNames);
    else { if(schView==='month') h+=buildMonthGrid(users,canEdit,dayNames,solo); else h+=buildWeekGrid(users,canEdit,dayNames,solo); }
  }else{
    if(schView==='month') h+=buildMonthGrid(users,canEdit,dayNames,solo);
    else h+=buildWeekGrid(users,canEdit,dayNames,solo);
  }

  let lg=BASE_SHIFTS.map(s=>`<div class="sch-legend-item"><div class="sch-legend-dot" style="background:${s.color}20;border:1px solid ${s.color}"></div>${s.icon} ${s.label}</div>`).join('');
  lg+=ae.map(e=>{const c=e.color||'#7C3AED';return `<div class="sch-legend-item"><div class="sch-legend-dot" style="background:${c}20;border:1px solid ${c}"></div>🎯 ${e.name}</div>`}).join('');
  h+=`<div class="sch-legend">${lg}</div>`;
  const ew=getEvtWarnings().filter(w=>w.event.endDate>=mk+'-01'&&w.event.startDate<=lm);
  if(ew.length){
    h+=`<div style="margin-top:10px;padding:10px 14px;border-radius:var(--r2);background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.12)">`;
    h+=`<div style="font-size:11px;font-weight:700;color:var(--red);margin-bottom:8px">⚠ Activities needing more staff (min ${MIN_STAFF} sales per day)</div>`;
    ew.forEach(w=>{
      const c=w.event.color||EVT_COLORS[0];
      const sd=w.days.filter(d=>d.short);
      h+=`<div style="margin-bottom:6px"><div style="font-size:11px;font-weight:600;color:${c}">🎯 ${w.event.name} <span style="font-weight:400;color:var(--t4)">(${w.event.startDate} → ${w.event.endDate})</span></div>`;
      h+=`<div style="display:flex;flex-wrap:wrap;gap:3px;margin-top:3px">${sd.map(d=>{const dn=new Date(d.date).toLocaleDateString('en',{weekday:'short',day:'numeric'});return `<span style="font-size:9px;padding:2px 8px;border-radius:4px;background:var(--red-g);color:var(--red);font-weight:600">${dn}: ${d.count}/${MIN_STAFF} ${d.names.length?'('+d.names.join(', ')+')':'(none)'}</span>`}).join('')}</div></div>`;
    });
    h+=`</div>`;
  }
  if(!ae.length) h+=`<div style="margin-top:8px;font-size:11px;color:var(--t4);text-align:center">💡 No activities this month. Create activities in the 🎯 Activity page first, then assign them here.</div>`;
  $('pgC').innerHTML=h;
}

function onSchEvtChange(){
  const v=$('schEvt')?.value||'All';
  window._schEvtFilter=v;
  if(v!=='All') schView='week'; // Auto-switch to week when activity selected
  renderSchedule();
}

function buildEvtScheduleView(evt,users,canEdit,dayNames){
  const schedules=G('al_schedules')||[];
  const c=evt.color||'#7C3AED';
  const today=localDate(new Date());
  const supF=document.getElementById('schSup')?.value||'All';
  const salF=document.getElementById('schSales')?.value||'All';
  let fu=users;
  if(supF!=='All') fu=users.filter(u=>u.supervisorId===Number(supF));
  if(salF!=='All') fu=users.filter(u=>u.username===salF);
  fu.sort((a,b)=>{const sa=a.supervisorId||999;const sb=b.supervisorId||999;if(sa!==sb) return sa-sb;return a.fullName.localeCompare(b.fullName)});

  // Build date range for this event
  const evtDays=[];
  const start=new Date(evt.startDate);const end=new Date(evt.endDate);
  for(let d=new Date(start);d<=end;d.setDate(d.getDate()+1)) evtDays.push(new Date(d));

  // Info banner
  let h=`<div style="padding:12px 16px;margin-bottom:10px;border-radius:var(--r2);border-left:4px solid ${c};background:${c}08;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
    <div>
      <div style="font-size:14px;font-weight:700;color:${c}">🎯 ${evt.name}</div>
      ${evt.location?`<div style="font-size:11px;color:var(--t3);margin-top:2px">📍 ${evt.location}</div>`:''}
      <div style="font-size:11px;color:var(--t2);margin-top:2px;font-family:'JetBrains Mono',monospace">${evt.startDate} → ${evt.endDate} (${evtDays.length} days)</div>
    </div>
    <div>${(()=>{const info=getEvtStaffing(evt.id);if(!info) return '';return info.totalShort>0?`<span style="background:var(--red-g);color:var(--red);font-size:10px;font-weight:700;padding:4px 10px;border-radius:10px">⚠ ${info.totalShort} day${info.totalShort>1?'s':''} understaffed</span>`:`<span style="background:var(--grn-g);color:var(--grn);font-size:10px;font-weight:700;padding:4px 10px;border-radius:10px">✓ All days staffed</span>`})()}</div>
  </div>`;

  // Grid showing only the event's date range
  h+=`<div class="sch-scroll"><div class="sch-grid" style="grid-template-columns:140px repeat(${evtDays.length},minmax(80px,1fr));min-width:${140+evtDays.length*80}px">`;
  h+=`<div class="sch-hdr" style="border-right:1px solid var(--bdr)">Sales Person</div>`;
  evtDays.forEach(d=>{
    const ds=localDate(d);
    const isToday=ds===today;
    const dow=dayNames[d.getDay()===0?6:d.getDay()-1];
    const assigned=schedules.filter(s=>s.date===ds&&s.eventId===evt.id).length;
    const short=assigned<MIN_STAFF;
    h+=`<div class="sch-hdr" style="${isToday?'background:var(--acc);color:#fff':''}">${dow}<br>${d.getDate()}<br><span style="font-size:9px;font-weight:800;color:${short?(isToday?'#fca5a5':'var(--red)'):(isToday?'#86efac':'var(--grn)')}">${assigned}/${MIN_STAFF}</span></div>`;
  });

  fu.forEach(u=>{
    const sup=userById(u.supervisorId);
    h+=`<div class="sch-name-col"><div class="perf-av rc-sales" style="width:28px;height:28px;font-size:10px">${initials(u.fullName)}</div><div style="min-width:0;overflow:hidden"><div style="white-space:nowrap;text-overflow:ellipsis;overflow:hidden">${u.fullName}</div>${sup?`<div style="font-size:9px;color:var(--t4);white-space:nowrap">${sup.fullName}</div>`:''}</div></div>`;

    evtDays.forEach(d=>{
      const ds=localDate(d);
      const isToday=ds===today;
      const entry=schedules.find(s=>s.date===ds&&s.username===u.username);
      const isAssigned=entry&&entry.eventId===evt.id;
      const hasOther=entry&&entry.shift&&!isAssigned;

      h+=`<div class="sch-cell${isToday?' today':''}${!canEdit?' readonly':''}" ${canEdit?`onclick="schClick('${ds}','${u.username}')"`:''} style="min-height:60px;${isAssigned?`background:${c}10;border-left:2px solid ${c}`:hasOther?'opacity:.6':''}">`;
      if(entry&&entry.shift){
        h+=shiftHtml(entry,false);
      }else{
        h+=`<div style="font-size:9px;color:var(--t4);text-align:center;padding:6px 0;opacity:.4">—</div>`;
      }
      h+=`</div>`;
    });
  });
  h+=`</div></div><div class="sch-swipe-hint">← Swipe to see more →</div>`;
  return h;
}

function buildMonthGrid(users,canEdit,dayNames,solo){
  const schedules=G('al_schedules')||[];const firstDay=new Date(schYear,schMonth,1);const lastDay=new Date(schYear,schMonth+1,0);
  let startDow=firstDay.getDay();startDow=startDow===0?6:startDow-1;
  const weeks=[];let cd=new Date(firstDay);cd.setDate(cd.getDate()-startDow);
  while(cd<=lastDay||cd.getDay()!==1){const wd=[];for(let d=0;d<7;d++){wd.push(new Date(cd));cd.setDate(cd.getDate()+1)}weeks.push(wd);if(cd>lastDay&&cd.getDay()===1) break}
  const today=localDate(new Date());const supF=document.getElementById('schSup')?.value||'All';const salF=document.getElementById('schSales')?.value||'All';
  let fu=users;
  if(supF!=='All') fu=users.filter(u=>u.supervisorId===Number(supF));
  if(salF!=='All') fu=users.filter(u=>u.username===salF);
  fu.sort((a,b)=>{const sa=a.supervisorId||999;const sb=b.supervisorId||999;if(sa!==sb) return sa-sb;return a.fullName.localeCompare(b.fullName)});
  const gridCols=solo?'repeat(7,1fr)':'150px repeat(7,1fr)';
  let h='';
  weeks.forEach((week,wi)=>{
    h+=`<div class="sch-scroll"><div class="sch-grid${solo?' sch-solo':''}" style="grid-template-columns:${gridCols}">`;
    if(!solo) h+=`<div class="sch-hdr" style="border-right:1px solid var(--bdr)">Sales Person</div>`;
    week.forEach(d=>{const ds=localDate(d);h+=`<div class="sch-hdr" style="${ds===today?'background:var(--acc);color:#fff':''}${d.getMonth()!==schMonth?';opacity:.4':''}">${dayNames[d.getDay()===0?6:d.getDay()-1]}<br>${d.getDate()}</div>`});
    fu.forEach(u=>{
      const sup=userById(u.supervisorId);
      if(!solo) h+=`<div class="sch-name-col"><div class="perf-av rc-sales" style="width:28px;height:28px;font-size:10px">${initials(u.fullName)}</div><div style="min-width:0;overflow:hidden"><div style="white-space:nowrap;text-overflow:ellipsis;overflow:hidden">${u.fullName}</div>${sup?`<div style="font-size:9px;color:var(--t4);white-space:nowrap">${sup.fullName}</div>`:''}</div></div>`;
      week.forEach(d=>{
        const ds=localDate(d);const entry=schedules.find(s=>s.date===ds&&s.username===u.username);
        
        h+=`<div class="sch-cell${ds===today?' today':''}${!canEdit?' readonly':''}" ${canEdit?`onclick="schClick('${ds}','${u.username}')"`:''} style="${d.getMonth()!==schMonth?'opacity:.35':''}${solo?';min-height:72px':''}">`;
        if(entry&&entry.shift) h+=shiftHtml(entry,solo);h+=`</div>`;
      });
    });
    h+=`</div></div>`;if(wi<weeks.length-1) h+=`<div style="height:6px"></div>`;
  });
  if(!solo) h+=`<div class="sch-swipe-hint">← Swipe to see more →</div>`;
  return h;
}

function buildWeekGrid(users,canEdit,dayNames,solo){
  const schedules=G('al_schedules')||[];const today=new Date();
  if(!schWeekStart){schWeekStart=new Date(schYear,schMonth,1);const dow=schWeekStart.getDay();schWeekStart.setDate(schWeekStart.getDate()-(dow===0?6:dow-1))}
  const week=[];const d=new Date(schWeekStart);for(let i=0;i<7;i++){week.push(new Date(d));d.setDate(d.getDate()+1)}
  const todayStr=localDate(today);const supF=document.getElementById('schSup')?.value||'All';const salF=document.getElementById('schSales')?.value||'All';
  let fu=users;
  if(supF!=='All') fu=users.filter(u=>u.supervisorId===Number(supF));
  if(salF!=='All') fu=users.filter(u=>u.username===salF);
  fu.sort((a,b)=>{const sa=a.supervisorId||999;const sb=b.supervisorId||999;if(sa!==sb) return sa-sb;return a.fullName.localeCompare(b.fullName)});
  const gridCols=solo?'repeat(7,1fr)':'150px repeat(7,1fr)';
  let h=`<div class="sch-scroll"><div class="sch-grid${solo?' sch-solo':''}" style="grid-template-columns:${gridCols}">`;
  if(!solo) h+=`<div class="sch-hdr" style="border-right:1px solid var(--bdr)">Sales Person</div>`;
  week.forEach(d=>{const ds=localDate(d);const mon=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][d.getMonth()];h+=`<div class="sch-hdr" style="${ds===todayStr?'background:var(--acc);color:#fff':''}">${dayNames[d.getDay()===0?6:d.getDay()-1]}<br>${d.getDate()} ${mon}</div>`});
  fu.forEach(u=>{
    const sup=userById(u.supervisorId);
    if(!solo) h+=`<div class="sch-name-col"><div class="perf-av rc-sales" style="width:28px;height:28px;font-size:10px">${initials(u.fullName)}</div><div style="min-width:0;overflow:hidden"><div style="white-space:nowrap;text-overflow:ellipsis;overflow:hidden">${u.fullName}</div>${sup?`<div style="font-size:9px;color:var(--t4);white-space:nowrap">${sup.fullName}</div>`:''}</div></div>`;
    week.forEach(d=>{
      const ds=localDate(d);const entry=schedules.find(s=>s.date===ds&&s.username===u.username);
      
      h+=`<div class="sch-cell${ds===todayStr?' today':''}${!canEdit?' readonly':''}" ${canEdit?`onclick="schClick('${ds}','${u.username}')"`:''} style="min-height:${solo?'80':'64'}px">`;
      if(entry&&entry.shift) h+=shiftHtml(entry,true);h+=`</div>`;
    });
  });
  h+=`</div></div>`;
  if(!solo) h+=`<div class="sch-swipe-hint">← Swipe to see more →</div>`;
  return h;
}

function schClick(date,username){
  const canEdit=['director','admin','branch_manager','sales_manager','supervisor'].includes(CU.role);if(!canEdit) return;
  const schedules=G('al_schedules')||[];const existing=schedules.find(s=>s.date===date&&s.username===username);
  const u=userByUn(username);const sup=u?userById(u.supervisorId):null;
  const dayLabel=new Date(date).toLocaleDateString('en',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
  const events=G('al_events')||[];
  const dayEvts=events.filter(e=>e.status!=='suggested'&&date>=e.startDate&&date<=e.endDate);

  const curShift=existing?existing.shift:'';
  const curEvtId=existing?existing.eventId||'':'';

  // Base shift buttons
  let shiftBtns=BASE_SHIFTS.map(s=>{
    const sel=curShift===s.id;const c=s.color;
    return `<button class="btn btn-sm sch-pick-shift" data-shift="${s.id}" style="flex:1;padding:10px 6px;font-size:11px;${sel?`background:${c};color:#fff;border-color:${c}`:`background:${c}15;border:1px solid ${c}40;color:${c}`}" onclick="schPickShift('${s.id}','${date}','${username}')">${s.icon} ${s.label}</button>`;
  }).join('');

  // Activity buttons
  let actBtns='';
  if(dayEvts.length){
    actBtns=dayEvts.map(e=>{
      const sel=curEvtId===e.id;const c=e.color||'#7C3AED';
      return `<button class="btn btn-sm sch-pick-evt" data-evt="${e.id}" style="width:100%;padding:10px 12px;font-size:12px;text-align:left;${sel?`background:${c};color:#fff;border-color:${c}`:`background:${c}15;border:1px solid ${c}40;color:${c}`}" onclick="schPickEvt(${e.id})">🎯 ${e.name}</button>`;
    }).join('');
  }

  const showActs=curShift&&curShift!=='off'&&dayEvts.length;

  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:420px">
    <div class="md-h"><span class="md-t">📅 Set Shift</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div style="text-align:center;margin-bottom:14px">
        <div style="font-size:15px;font-weight:700;color:var(--t1)">${u?u.fullName:username}</div>
        ${sup?`<div style="font-size:11px;color:var(--t4);margin-top:2px">Supervisor: ${sup.fullName}</div>`:''}
        <div style="font-size:12px;color:var(--acc);margin-top:4px;font-weight:600">${dayLabel}</div>
      </div>
      <div style="font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">1. Regular Shift</div>
      <div style="display:flex;gap:6px;margin-bottom:14px">${shiftBtns}</div>
      <div id="schActSection" style="${showActs?'':'display:none'}">
        <div style="font-size:10px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px">2. Activity Assignment</div>
        <div style="display:flex;flex-direction:column;gap:6px" id="schActBtns">${actBtns}</div>
        ${!dayEvts.length?`<div style="font-size:11px;color:var(--t4);text-align:center;padding:10px 0">No activities on this date</div>`:''}
      </div>
      <input type="hidden" id="schSelShift" value="${curShift}">
      <input type="hidden" id="schSelEvt" value="${curEvtId}">
    </div>
    <div class="md-f">
      ${existing?`<button class="btn btn-s btn-sm" onclick="schClear('${date}','${username}')" style="color:var(--red);margin-right:auto">✕ Clear</button>`:'<div></div>'}
      <button class="btn btn-s" onclick="closeMd()">Cancel</button>
      <button class="btn btn-p" onclick="schSave('${date}','${username}')">Save</button>
    </div>
  </div></div>`;
}

function schPickShift(shiftId,date,username){
  $('schSelShift').value=shiftId;
  // Highlight selected shift
  document.querySelectorAll('.sch-pick-shift').forEach(b=>{
    const s=BASE_SHIFTS.find(x=>x.id===b.dataset.shift);if(!s) return;
    const sel=b.dataset.shift===shiftId;const c=s.color;
    b.style.background=sel?c:`${c}15`;b.style.color=sel?'#fff':c;b.style.borderColor=sel?c:`${c}40`;
  });
  // Show/hide activity section
  const actSec=$('schActSection');
  if(shiftId==='off'){
    actSec.style.display='none';
    $('schSelEvt').value='';
    // Clear activity highlights
    document.querySelectorAll('.sch-pick-evt').forEach(b=>{
      const evts=G('al_events')||[];const e=evts.find(x=>x.id===Number(b.dataset.evt));
      if(e){const c=e.color||'#7C3AED';b.style.background=`${c}15`;b.style.color=c;b.style.borderColor=`${c}40`}
    });
  }else{
    const events=G('al_events')||[];
    const dayEvts=events.filter(e=>e.status!=='suggested'&&date>=e.startDate&&date<=e.endDate);
    actSec.style.display=dayEvts.length?'':'none';
  }
}

function schPickEvt(evtId){
  const cur=$('schSelEvt').value;
  const newVal=Number(cur)===evtId?'':evtId; // Toggle
  $('schSelEvt').value=newVal;
  // Highlight
  document.querySelectorAll('.sch-pick-evt').forEach(b=>{
    const eid=Number(b.dataset.evt);const sel=eid===Number(newVal);
    const evts=G('al_events')||[];const e=evts.find(x=>x.id===eid);
    if(e){const c=e.color||'#7C3AED';b.style.background=sel?c:`${c}15`;b.style.color=sel?'#fff':c;b.style.borderColor=sel?c:`${c}40`}
  });
}

function schSave(date,username){
  const shift=$('schSelShift').value;
  if(!shift){toast('Select a shift first');return}
  const eventId=shift==='off'?null:($('schSelEvt').value?Number($('schSelEvt').value):null);
  let schedules=G('al_schedules')||[];
  schedules=schedules.filter(s=>!(s.date===date&&s.username===username));
  schedules.push({date,username,shift,eventId,setBy:CU.username,setAt:new Date().toISOString()});
  S('al_schedules',schedules);closeMd();renderSchedule();
}

function schSet(date,username,shiftId){
  let schedules=G('al_schedules')||[];
  schedules=schedules.filter(s=>!(s.date===date&&s.username===username));
  schedules.push({date,username,shift:shiftId,eventId:null,setBy:CU.username,setAt:new Date().toISOString()});
  S('al_schedules',schedules);closeMd();renderSchedule();
}
function schClear(date,username){
  let schedules=G('al_schedules')||[];
  schedules=schedules.filter(s=>!(s.date===date&&s.username===username));
  S('al_schedules',schedules);closeMd();renderSchedule();
}
function schPrev(){if(schView==='week'&&schWeekStart){schWeekStart.setDate(schWeekStart.getDate()-7);schMonth=schWeekStart.getMonth();schYear=schWeekStart.getFullYear()}else{schMonth--;if(schMonth<0){schMonth=11;schYear--}}renderSchedule()}
function schNext(){if(schView==='week'&&schWeekStart){schWeekStart.setDate(schWeekStart.getDate()+7);schMonth=schWeekStart.getMonth();schYear=schWeekStart.getFullYear()}else{schMonth++;if(schMonth>11){schMonth=0;schYear++}}renderSchedule()}
function schToday(){const t=new Date();schYear=t.getFullYear();schMonth=t.getMonth();if(schView==='week'){schWeekStart=new Date(t);const dow=schWeekStart.getDay();schWeekStart.setDate(schWeekStart.getDate()-(dow===0?6:dow-1))}renderSchedule()}
function schSetWeekView(){schView='week';const t=new Date();schWeekStart=new Date(schYear,schMonth,1);const dow=schWeekStart.getDay();schWeekStart.setDate(schWeekStart.getDate()-(dow===0?6:dow-1));if(t.getMonth()===schMonth&&t.getFullYear()===schYear){schWeekStart=new Date(t);const d2=schWeekStart.getDay();schWeekStart.setDate(schWeekStart.getDate()-(d2===0?6:d2-1))}renderSchedule()}


