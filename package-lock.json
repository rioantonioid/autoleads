function openImportCSV(){
  const canImport=['director','admin','branch_manager','sales_manager'].includes(CU.role);
  if(!canImport){toast('Only managers can import');return}
  $('csvFileInput').click();
}

function handleCSVFile(e){
  const file=e.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=function(ev){
    const text=ev.target.result;
    parseAndPreviewCSV(text);
  };
  reader.readAsText(file);
  e.target.value='';// Reset so same file can be re-selected
}

function parseCSVLine(line){
  const result=[];let current='';let inQuotes=false;
  for(let i=0;i<line.length;i++){
    const ch=line[i];
    if(inQuotes){
      if(ch==='"'&&line[i+1]==='"'){current+='"';i++}
      else if(ch==='"'){inQuotes=false}
      else{current+=ch}
    }else{
      if(ch==='"'){inQuotes=true}
      else if(ch===','){result.push(current.trim());current=''}
      else{current+=ch}
    }
  }
  result.push(current.trim());
  return result;
}

function parseAndPreviewCSV(text){
  const lines=text.split(/\r?\n/).filter(l=>l.trim());
  if(lines.length<2){toast('CSV must have headers and at least 1 row');return}

  const headers=parseCSVLine(lines[0]).map(h=>h.toLowerCase().replace(/[^a-z ]/g,'').trim());

  // Map common header names
  const colMap={};
  const findCol=(names)=>headers.findIndex(h=>names.some(n=>h.includes(n)));
  colMap.name=findCol(['name','customer','nama']);
  colMap.phone=findCol(['phone','hp','telp','nomor','number']);
  colMap.carType=findCol(['car','type','model','kendaraan','mobil']);
  colMap.source=findCol(['source','sumber']);
  colMap.date=findCol(['lead date','date','tanggal','tgl']);
  colMap.status=findCol(['status']);
  colMap.followUp=findCol(['follow','tindak']);
  colMap.notes=findCol(['note','catatan','keterangan']);
  colMap.salesPerson=findCol(['sales person','sales','salesperson','assigned','pic']);

  if(colMap.name===-1||colMap.phone===-1){
    toast('CSV must have Name and Phone columns');return;
  }

  // Get all sales users for matching/assignment
  const allUsers=G('al_users').filter(u=>u.active);
  const salesUsers=allUsers.filter(u=>['sales','supervisor'].includes(u.role));

  const rows=[];
  for(let i=1;i<lines.length;i++){
    const cols=parseCSVLine(lines[i]);
    if(!cols[colMap.name]&&!cols[colMap.phone])continue;
    const phone=(cols[colMap.phone]||'').replace(/^="?|"?$/g,'').trim();
    if(!phone)continue;

    // Try to match sales person from CSV
    let assignedTo='';
    if(colMap.salesPerson>=0){
      const csvSales=(cols[colMap.salesPerson]||'').trim().toLowerCase();
      if(csvSales){
        const match=allUsers.find(u=>u.fullName.toLowerCase()===csvSales||u.username.toLowerCase()===csvSales);
        if(match) assignedTo=match.username;
      }
    }

    rows.push({
      name:cols[colMap.name]||'',
      phone,
      carType:colMap.carType>=0?cols[colMap.carType]||'Sedan':'Sedan',
      source:colMap.source>=0?cols[colMap.source]||'Walk-in':'Walk-in',
      date:colMap.date>=0?cols[colMap.date]||new Date().toISOString().split('T')[0]:new Date().toISOString().split('T')[0],
      status:colMap.status>=0?cols[colMap.status]||'Hot':'Hot',
      followUp:colMap.followUp>=0?cols[colMap.followUp]||'':'',
      notes:colMap.notes>=0?cols[colMap.notes]||'':'',
      _assignedTo:assignedTo,
    });
  }

  if(!rows.length){toast('No valid rows found in CSV');return}

  // Check duplicates
  const leads=G('al_leads');
  rows.forEach(r=>{
    const cleanPhone=r.phone.replace(/[^0-9]/g,'');
    const existing=leads.find(l=>l.phone.replace(/[^0-9]/g,'')===cleanPhone);
    r._dup=!!existing;
    r._existingId=existing?existing.id:null;
    r._action=existing?'skip':'new';
  });

  const newCount=rows.filter(r=>!r._dup).length;
  const dupCount=rows.filter(r=>r._dup).length;
  const matchedCount=rows.filter(r=>r._assignedTo).length;

  // Sales person dropdown options
  const salesOpts=`<option value="">— Assign To (from CSV) —</option><option value="__me__">Myself (${CU.fullName})</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName} (${rLabel(u.role)})</option>`).join('')}`;

  // Show preview modal
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:640px">
    <div class="md-h"><span class="md-t">📤 Import CSV Preview</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div class="import-summary">
        <span style="color:var(--t1)">📄 ${rows.length} rows</span>
        <span style="color:var(--grn)">✚ ${newCount} new</span>
        ${dupCount?`<span style="color:var(--org)">⚠ ${dupCount} dup</span>`:''}
        ${matchedCount?`<span style="color:var(--acc)">👤 ${matchedCount} matched</span>`:''}
      </div>

      <div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:12px;margin-bottom:12px">
        <div style="font-size:11px;font-weight:600;color:var(--t1);margin-bottom:6px">👤 Assign Leads To</div>
        <select class="fs" id="importAssign" onchange="updateImportAssign()" style="font-size:12px">${salesOpts}</select>
        <div style="font-size:10px;color:var(--t4);margin-top:4px">${matchedCount?`${matchedCount} leads matched from CSV "Sales Person" column. Override with dropdown above, or leave blank to use CSV data.`:'Select a sales person to assign all imported leads to, or leave blank to assign to yourself.'}</div>
      </div>

      ${dupCount?`<div style="background:var(--org-g);border:1px solid rgba(180,83,9,.2);border-radius:var(--r);padding:10px 12px;margin-bottom:12px;font-size:11px;color:var(--org)">
        <b>Duplicate phone numbers found.</b>
        <div class="dup-choice">
          <button class="btn btn-s btn-sm" onclick="setAllDupAction('skip')" id="dupSkipBtn" style="border-color:var(--org)">Skip All Duplicates</button>
          <button class="btn btn-s btn-sm" onclick="setAllDupAction('overwrite')" id="dupOverBtn">Overwrite All</button>
        </div>
      </div>`:``}
      <div class="import-preview" id="importPreview">
        ${rows.map((r,i)=>{
          const assignUser=r._assignedTo?allUsers.find(u=>u.username===r._assignedTo):null;
          return `<div class="import-row">
            <div class="ir-name">${r.name}</div>
            <div class="ir-phone">${r.phone}</div>
            <div style="font-size:10px;color:var(--t4);flex:1">${r.carType} · ${r.source}</div>
            <div style="font-size:9px;color:var(--acc);min-width:60px" id="irAssign${i}">${assignUser?'👤 '+assignUser.fullName:''}</div>
            <div class="ir-status"><span class="ir-tag ${r._dup?'ir-dup':'ir-new'}">${r._dup?'DUPLICATE':'NEW'}</span></div>
          </div>`;
        }).join('')}
      </div>
    </div>
    <div class="md-f">
      <span style="font-size:10px;color:var(--t4);margin-right:auto" id="importCount">Will import: ${newCount} leads</span>
      <button class="btn btn-s" onclick="closeMd()">Cancel</button>
      <button class="btn btn-p" onclick="executeImport()">Import</button>
    </div>
  </div></div>`;

  window._importRows=rows;
}

function updateImportAssign(){
  if(!window._importRows)return;
  const val=$('importAssign')?.value||'';
  const allUsers=G('al_users').filter(u=>u.active);
  window._importRows.forEach((r,i)=>{
    if(val){
      // Override all assignments
      r._assignOverride=val==='__me__'?CU.username:val;
    }else{
      delete r._assignOverride;
    }
    const assignUn=r._assignOverride||r._assignedTo;
    const assignUser=assignUn?allUsers.find(u=>u.username===assignUn):null;
    const el=$('irAssign'+i);
    if(el) el.innerHTML=assignUser?'👤 '+assignUser.fullName:'';
  });
}

function setAllDupAction(action){
  if(!window._importRows)return;
  window._importRows.forEach(r=>{if(r._dup)r._action=action});
  const newC=window._importRows.filter(r=>r._action==='new'||r._action==='overwrite').length;
  const ic=$('importCount');if(ic)ic.textContent='Will import: '+newC+' leads';

  // Update preview tags
  const preview=$('importPreview');
  if(preview){
    const tags=preview.querySelectorAll('.ir-tag');
    window._importRows.forEach((r,i)=>{
      if(tags[i]&&r._dup){
        if(action==='skip'){tags[i].className='ir-tag ir-skip';tags[i].textContent='SKIP'}
        else{tags[i].className='ir-tag ir-dup';tags[i].textContent='OVERWRITE'}
      }
    });
  }
  // Highlight active button
  const sb=$('dupSkipBtn'),ob=$('dupOverBtn');
  if(sb&&ob){
    sb.style.borderColor=action==='skip'?'var(--org)':'var(--bdr)';
    sb.style.fontWeight=action==='skip'?'700':'600';
    ob.style.borderColor=action==='overwrite'?'var(--org)':'var(--bdr)';
    ob.style.fontWeight=action==='overwrite'?'700':'600';
  }
}

function executeImport(){
  if(!window._importRows){toast('No data to import');return}
  const rows=window._importRows;
  let leads=G('al_leads');
  const now=new Date().toISOString().split('T')[0];
  let imported=0,skipped=0,overwritten=0;

  rows.forEach(r=>{
    if(r._dup&&r._action==='skip'){skipped++;return}
    // Determine assigned sales person
    const assignTo=r._assignOverride||r._assignedTo||CU.username;

    if(r._dup&&r._action==='overwrite'){
      leads=leads.map(l=>Number(l.id)===Number(r._existingId)?{...l,name:r.name,phone:r.phone,carType:r.carType,source:r.source,date:r.date,status:r.status,followUp:r.followUp||l.followUp,notes:r.notes||l.notes,createdBy:assignTo,updatedAt:now,updatedBy:CU.username}:l);
      overwritten++;
      return;
    }
    // New lead
    leads.unshift({
      id:Date.now()+imported,name:r.name,phone:r.phone,carType:r.carType,
      source:r.source,date:r.date,status:r.status,followUp:r.followUp,
      notes:r.notes,createdBy:assignTo,createdAt:now,updatedAt:now,updatedBy:CU.username
    });
    imported++;
  });

  S('al_leads',leads);
  window._importRows=null;
  closeMd();buildNav();

  let msg=`Imported ${imported} new`;
  if(overwritten) msg+=`, ${overwritten} overwritten`;
  if(skipped) msg+=`, ${skipped} skipped`;
  toast(msg);
}

/* ═══════════════════════════════════════
   EXPORT CSV
   ═══════════════════════════════════════ */
function expCSV(type){
  let leads,filename;
  const all=getVisibleLeads();
  if(type==='leads'){leads=all.filter(l=>!l.spkSection&&!l.doSection&&l.status!=='LOST');filename='Leads'}
  else if(type==='spk'){leads=all.filter(l=>l.spkSection&&!l.doSection);filename='SPK'}
  else if(type==='do'){leads=all.filter(l=>l.doSection);filename='DO'}
  else if(type==='lost'){leads=G('al_leads').filter(l=>l.status==='LOST'&&!l.spkSection&&!l.doSection);filename='Lost'}
  else{leads=all;filename='All'}
  if(!leads.length){toast('No data to export');return}
  const esc=v=>{const s=String(v||'');if(!s)return '';return s.includes(',')||s.includes('"')||s.includes('\n')?'"'+s.replace(/"/g,'""')+'"':s};
  const escPhone=v=>{const s=String(v||'');return s?'="'+s+'"':''};
  const h=['Name','Phone','Car Type','Source','Lead Date','Status','Follow Up','Notes','Sales Person','Supervisor','Created At','SPK Date','DO Date','Section'];
  let csv=h.join(',')+'\n';
  leads.forEach(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const section=l.doSection?'DO':l.spkSection?'SPK':'Lead';
    csv+=[esc(l.name),escPhone(l.phone),esc(l.carType),esc(l.source),l.date||'',l.status||'',l.followUp||'',esc(l.notes),esc(u?u.fullName:l.createdBy),esc(sup?sup.fullName:''),l.createdAt||'',l.spkDate||'',l.doDate||'',section].join(',')+'\n';
  });
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=`CheryBatam_${filename}_${CU.role}_${new Date().toISOString().split('T')[0]}.csv`;
  document.body.appendChild(a);a.click();document.body.removeChild(a);
  toast(filename+' CSV exported — open in Google Sheets');
}

/* ═══════════════════════════════════════
   EXPORT DO ZIP (Photos + CSV)
   ═══════════════════════════════════════ */
function expDOZip(){
  if(typeof JSZip==='undefined'){toast('ZIP library not loaded. Please refresh.');return}
  const doLeads=getVisibleLeads().filter(l=>l.doSection);
  if(!doLeads.length){toast('No DO data to export');return}

  const withPhoto=doLeads.filter(l=>l.doPhoto);
  const noPhoto=doLeads.length-withPhoto.length;

  // Show progress
  toast('Preparing ZIP... '+doLeads.length+' items');

  const zip=new JSZip();
  const photoFolder=zip.folder('photos');
  const td=new Date().toISOString().split('T')[0];

  // Add CSV
  const esc=v=>{const s=String(v||'');return s.includes(',')?'"'+s+'"':s};
  const escPhone=v=>{const s=String(v||'');return s?'="'+s+'"':''};
  let csv='Name,Phone,DO Date,SPK Date,Lead Date,Car Type,Source,Sales Person,Supervisor,Photo File\n';
  let idx=1;

  doLeads.forEach(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const safeName=(l.name||'lead').replace(/[^a-zA-Z0-9 ]/g,'').replace(/\s+/g,'_').slice(0,30);
    const salesName=(u?u.fullName:'unknown').replace(/[^a-zA-Z0-9 ]/g,'').replace(/\s+/g,'_').slice(0,20);
    const photoFile=l.doPhoto?`${String(idx).padStart(3,'0')}_${safeName}_by_${salesName}.jpg`:'';

    // Add photo to zip
    if(l.doPhoto){
      const b64=l.doPhoto.split(',')[1];
      if(b64) photoFolder.file(photoFile,b64,{base64:true});
    }

    csv+=[esc(l.name),escPhone(l.phone),l.doDate||'',l.spkDate||'',l.date||'',esc(l.carType),esc(l.source),esc(u?u.fullName:l.createdBy),esc(sup?sup.fullName:''),photoFile].join(',')+'\n';
    idx++;
  });

  zip.file('DO_Results.csv',csv);

  // Add summary text
  let summary=`Chery Batam CRM — DO Results Export\n`;
  summary+=`Date: ${td}\n`;
  summary+=`Exported by: ${CU.fullName} (${rLabel(CU.role)})\n`;
  summary+=`Total DO: ${doLeads.length}\n`;
  summary+=`With photos: ${withPhoto.length}\n`;
  if(noPhoto) summary+=`Missing photos: ${noPhoto}\n`;
  summary+=`\n--- Delivery Orders ---\n\n`;
  doLeads.forEach((l,i)=>{
    const u=userByUn(l.createdBy);
    summary+=`${i+1}. ${l.name} | ${l.phone} | DO: ${l.doDate||'N/A'} | Sales: ${u?u.fullName:l.createdBy}\n`;
  });
  zip.file('README.txt',summary);

  // Generate and download
  zip.generateAsync({type:'blob'}).then(blob=>{
    const a=document.createElement('a');
    a.href=URL.createObjectURL(blob);
    a.download=`CheryBatam_DO_Photos_${td}.zip`;
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    toast(`ZIP exported: ${doLeads.length} DO, ${withPhoto.length} photos`);
  }).catch(err=>{
    toast('Export failed: '+err.message);
  });
}

/* ═══════════════════════════════════════
   EXPORT — Schedule, Events, Users, All ZIP
   ═══════════════════════════════════════ */
function csvEsc(v){const s=String(v??'');if(!s)return '';return s.includes(',')||s.includes('"')||s.includes('\n')?'"'+s.replace(/"/g,'""')+'"':s}
function csvPhone(v){const s=String(v||'');return s?'="'+s+'"':''}
function dlCSV(csv,name){
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download=`CheryBatam_${name}_${localDate(new Date())}.csv`;
  document.body.appendChild(a);a.click();document.body.removeChild(a);
  toast(name+' CSV exported');
}

function expScheduleCSV(){
  const schedules=G('al_schedules')||[];
  if(!schedules.length){toast('No schedule data');return}
  let csv='Date,Day,Sales Person,Supervisor,Shift,Activity\n';
  const dayN=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  schedules.sort((a,b)=>a.date.localeCompare(b.date)||a.username.localeCompare(b.username));
  schedules.forEach(s=>{
    const u=userByUn(s.username);const sup=u?userById(u.supervisorId):null;
    const base=BASE_SHIFTS.find(x=>x.id===s.shift);
    const shiftLabel=base?base.label:s.shift||'';
    let actName='';
    if(s.eventId){const events=G('al_events')||[];const evt=events.find(e=>e.id===s.eventId);if(evt) actName=evt.name}
    const d=new Date(s.date);const dayName=dayN[d.getDay()];
    csv+=[s.date,dayName,csvEsc(u?u.fullName:s.username),csvEsc(sup?sup.fullName:''),csvEsc(shiftLabel),csvEsc(actName)].join(',')+'\n';
  });
  dlCSV(csv,'Schedule');
}

function expEventsCSV(){
  const events=G('al_events')||[];
  if(!events.length){toast('No activity data');return}
  let csv='Event Name,Location,Start Date,End Date,Duration (Days),Status,Staff Per Day,Created By,Created At\n';
  events.forEach(e=>{
    const days=Math.round((new Date(e.endDate)-new Date(e.startDate))/86400000)+1;
    const info=getEvtStaffing(e.id);
    const minStaff=info?info.minStaff:0;
    const createdByUser=userByUn(e.createdBy);
    csv+=[csvEsc(e.name),csvEsc(e.location||''),e.startDate,e.endDate,days,e.status||'active',minStaff>=99?0:minStaff,csvEsc(createdByUser?createdByUser.fullName:e.createdBy),e.createdAt||''].join(',')+'\n';
  });
  dlCSV(csv,'Activities');
}

function expUsersCSV(){
  const users=G('al_users')||[];
  if(!users.length){toast('No user data');return}
  let csv='Full Name,Username,Role,Supervisor,Status,Created At\n';
  users.forEach(u=>{
    const sup=userById(u.supervisorId);
    csv+=[csvEsc(u.fullName),u.username,rLabel(u.role),csvEsc(sup?sup.fullName:''),u.active?'Active':'Disabled',u.createdAt||''].join(',')+'\n';
  });
  dlCSV(csv,'Users');
}

function expAllZip(){
  if(typeof JSZip==='undefined'){toast('ZIP library not loaded. Please refresh.');return}
  toast('Preparing full export...');
  const zip=new JSZip();
  const td=localDate(new Date());
  const esc=csvEsc;const escP=csvPhone;

  // 1. All Leads
  const allLeads=getVisibleLeads();
  if(allLeads.length){
    let csv='Name,Phone,Car Type,Source,Lead Date,Status,Follow Up,Notes,Sales Person,Supervisor,Created At,SPK Date,DO Date,Section\n';
    allLeads.forEach(l=>{
      const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
      const section=l.doSection?'DO':l.spkSection?'SPK':l.status==='LOST'?'LOST':'Lead';
      csv+=[esc(l.name),escP(l.phone),esc(l.carType),esc(l.source),l.date||'',l.status||'',l.followUp||'',esc(l.notes),esc(u?u.fullName:l.createdBy),esc(sup?sup.fullName:''),l.createdAt||'',l.spkDate||'',l.doDate||'',section].join(',')+'\n';
    });
    zip.file('Leads_All.csv',csv);
  }

  // 2. Schedule
  const schedules=G('al_schedules')||[];
  if(schedules.length){
    const dayN=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    let csv='Date,Day,Sales Person,Supervisor,Shift,Activity\n';
    schedules.sort((a,b)=>a.date.localeCompare(b.date));
    schedules.forEach(s=>{
      const u=userByUn(s.username);const sup=u?userById(u.supervisorId):null;
      const base=BASE_SHIFTS.find(x=>x.id===s.shift);
      let actName='';if(s.eventId){const evts=G('al_events')||[];const evt=evts.find(e=>e.id===s.eventId);if(evt) actName=evt.name}
      const d=new Date(s.date);
      csv+=[s.date,dayN[d.getDay()],esc(u?u.fullName:s.username),esc(sup?sup.fullName:''),esc(base?base.label:s.shift||''),esc(actName)].join(',')+'\n';
    });
    zip.file('Schedule.csv',csv);
  }

  // 3. Activities/Events
  const events=G('al_events')||[];
  if(events.length){
    let csv='Event Name,Location,Start Date,End Date,Duration,Status,Min Staff,Created By\n';
    events.forEach(e=>{
      const days=Math.round((new Date(e.endDate)-new Date(e.startDate))/86400000)+1;
      const info=getEvtStaffing(e.id);
      const createdByUser=userByUn(e.createdBy);
      csv+=[esc(e.name),esc(e.location||''),e.startDate,e.endDate,days,e.status||'',info?info.minStaff>=99?0:info.minStaff:0,esc(createdByUser?createdByUser.fullName:e.createdBy)].join(',')+'\n';
    });
    zip.file('Activities.csv',csv);
  }

  // 4. Users
  const users=G('al_users')||[];
  if(users.length){
    let csv='Full Name,Username,Role,Supervisor,Status,Created At\n';
    users.forEach(u=>{
      const sup=userById(u.supervisorId);
      csv+=[esc(u.fullName),u.username,rLabel(u.role),esc(sup?sup.fullName:''),u.active?'Active':'Disabled',u.createdAt||''].join(',')+'\n';
    });
    zip.file('Users.csv',csv);
  }

  // 5. Performance
  const salesUsers=users.filter(u=>u.role==='sales'&&u.active);
  if(salesUsers.length){
    const thisYear=String(new Date().getFullYear());
    let csv='Sales Person,Supervisor,Total Leads,Hot,Warm,Cold,SPK,DO,LOST,SPK This Year\n';
    salesUsers.forEach(u=>{
      const sup=userById(u.supervisorId);
      const uLeads=allLeads.filter(l=>l.createdBy===u.username);
      csv+=[esc(u.fullName),esc(sup?sup.fullName:''),uLeads.length,
        uLeads.filter(l=>l.status==='Hot').length,
        uLeads.filter(l=>l.status==='Warm').length,
        uLeads.filter(l=>l.status==='Cold').length,
        uLeads.filter(l=>l.spkSection).length,
        uLeads.filter(l=>l.doSection).length,
        uLeads.filter(l=>l.status==='LOST').length,
        G('al_leads').filter(l=>l.spkSection&&l.date&&l.date.startsWith(thisYear)&&l.createdBy===u.username).length
      ].join(',')+'\n';
    });
    zip.file('Performance.csv',csv);
  }

  // 6. Activity Log
  const acts=G('al_activities')||[];
  if(acts.length){
    let csv='Lead ID,User,Action,Detail,Date,Time\n';
    acts.slice(0,5000).forEach(a=>{
      const au=userByUn(a.user);
      csv+=[a.leadId,esc(au?au.fullName:a.user),a.action,esc(a.detail),a.date,a.time].join(',')+'\n';
    });
    zip.file('Activity_Log.csv',csv);
  }

  // 7. DO Photos
  const doLeads=allLeads.filter(l=>l.doSection&&l.doPhoto);
  if(doLeads.length){
    const photoFolder=zip.folder('DO_Photos');
    doLeads.forEach((l,i)=>{
      const u=userByUn(l.createdBy);
      const safeName=(l.name||'lead').replace(/[^a-zA-Z0-9 ]/g,'').replace(/\s+/g,'_').slice(0,30);
      const salesName=(u?u.fullName:'unknown').replace(/[^a-zA-Z0-9 ]/g,'').replace(/\s+/g,'_').slice(0,20);
      const b64=l.doPhoto.split(',')[1];
      if(b64) photoFolder.file(`${String(i+1).padStart(3,'0')}_${safeName}_by_${salesName}.jpg`,b64,{base64:true});
    });
  }

  // README
  let readme=`CheryBatam CRM — Full Export\n`;
  readme+=`Exported: ${td}\n`;
  readme+=`Exported by: ${CU.fullName} (${rLabel(CU.role)})\n\n`;
  readme+=`Files included:\n`;
  readme+=`- Leads_All.csv — All leads (${allLeads.length})\n`;
  readme+=`- Schedule.csv — Sales schedule (${schedules.length} entries)\n`;
  readme+=`- Activities.csv — Events/activities (${events.length})\n`;
  readme+=`- Users.csv — User accounts (${users.length})\n`;
  readme+=`- Performance.csv — Sales performance (${salesUsers.length} sales)\n`;
  readme+=`- Activity_Log.csv — Lead activity log (${Math.min(acts.length,5000)} entries)\n`;
  if(doLeads.length) readme+=`- DO_Photos/ — Delivery photos (${doLeads.length} photos)\n`;
  zip.file('README.txt',readme);

  zip.generateAsync({type:'blob'}).then(blob=>{
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);
    a.download=`CheryBatam_FullExport_${td}.zip`;
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    toast(`Full export: ${allLeads.length} leads, ${schedules.length} schedules, ${events.length} activities, ${doLeads.length} photos`);
  }).catch(err=>toast('Export failed: '+err.message));
}

/* ═══════════════════════════════════════
   FOLLOW-UP COUNTDOWN + AUTO-LOST
   ═══════════════════════════════════════ */
function fuCountdown(followUpDate){
  if(!followUpDate) return `<span style="color:var(--t4)">—</span>`;
  const now=new Date();now.setHours(0,0,0,0);
  const fu=new Date(followUpDate);fu.setHours(0,0,0,0);
  const diff=Math.round((fu-now)/(86400000));
  if(diff>1) return `<span style="color:var(--grn);font-weight:600">${diff} days</span>`;
  if(diff===1) return `<span style="color:var(--org);font-weight:600">Tomorrow</span>`;
  if(diff===0) return `<span style="color:var(--red);font-weight:700">Today!</span>`;
  if(diff===-1) return `<span style="color:var(--red);font-weight:700">⚠ 1 day overdue</span>`;
  return `<span style="color:var(--red);font-weight:700">⚠ ${Math.abs(diff)} days overdue</span>`;
}

function autoLost(){
  const leads=G('al_leads');
  const now=new Date();now.setHours(0,0,0,0);
  let changed=0;
  const updated=leads.map(l=>{
    if(l.status==='LOST'||l.status==='SPK'||l.spkSection||l.doSection) return l;
    const lastDate=l.updatedAt||l.createdAt;
    if(!lastDate) return l;
    const last=new Date(lastDate);last.setHours(0,0,0,0);
    const days=Math.round((now-last)/86400000);
    if(days>=14){
      changed++;
      addActivity(l.id,'status','Auto-moved to LOST (no update for '+days+' days)');
      return {...l,status:'LOST',updatedAt:now.toISOString().split('T')[0],updatedBy:'system'};
    }
    return l;
  });
  if(changed){S('al_leads',updated);toast(changed+' lead'+(changed>1?'s':'')+' auto-moved to LOST (14 days inactive)');}
}

