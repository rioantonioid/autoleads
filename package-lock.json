function yearOpts(leads){
  const years=new Set();
  leads.forEach(l=>{if(l.date)years.add(l.date.slice(0,4))});
  const sorted=[...years].sort().reverse();
  return `<option value="All">All Years</option>${sorted.map(y=>`<option value="${y}">${y}</option>`).join('')}`;
}

