function buildStockColorSettings(){
  const colors=getStockColors();
  const entries=Object.entries(colors);
  let h=`<div class="set-card"><div class="set-title">Stock Colors</div>
    <div style="font-size:10px;color:var(--t4);margin-bottom:8px">Colors available when adding stock. Tap a color to edit, ✕ to remove.</div>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px">`;
  entries.forEach(([name,hex])=>{
    const dark=isDarkHex(hex);
    h+=`<div style="display:flex;align-items:center;gap:4px;background:var(--bg3);border:1px solid var(--bdr);border-radius:8px;padding:4px 8px 4px 4px">
      <div style="width:22px;height:22px;border-radius:6px;background:${hex};border:2px solid ${dark?hex:'var(--bdr)'};cursor:pointer" onclick="editStockColor('${name}','${hex}')"></div>
      <span style="font-size:11px;font-weight:600;color:var(--t2);cursor:pointer" onclick="editStockColor('${name}','${hex}')">${name}</span>
      <span style="cursor:pointer;opacity:.4;font-size:11px;margin-left:2px" onclick="removeStockColor('${name}')">✕</span>
    </div>`;
  });
  h+=`</div>
    <div class="add-row">
      <input class="fi" id="newStkColorName" placeholder="Color name" style="max-width:120px">
      <input class="fi" id="newStkColorHex" type="color" value="#3B82F6" style="max-width:50px;padding:2px;height:34px;cursor:pointer">
      <button class="btn btn-p btn-sm" onclick="addStockColor()">+ Add</button>
    </div>
  </div>`;
  return h;
}

function addStockColor(){
  const name=$('newStkColorName').value.trim();
  const hex=$('newStkColorHex').value;
  if(!name){toast('Enter a color name');return}
  const colors=getStockColors();
  if(colors[name]){toast('Color name already exists');return}
  colors[name]=hex;
  S('al_stock_colors',colors);
  renderSets();toast('Color added');
}

function removeStockColor(name){
  const colors=getStockColors();
  if(Object.keys(colors).length<=1){toast('Must have at least 1 color');return}
  delete colors[name];
  S('al_stock_colors',colors);
  renderSets();toast('Color removed');
}

function editStockColor(name,hex){
  $('modalC').classList.remove('hidden');
  $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:360px">
    <div class="md-h"><span class="md-t">🎨 Edit Color</span><button class="md-x" onclick="closeMd()">✕</button></div>
    <div class="md-b">
      <div class="fg"><label class="fl">Color Name</label><input class="fi" id="editStkCName" value="${name}"></div>
      <div class="fg"><label class="fl">Color</label>
        <div style="display:flex;align-items:center;gap:10px;margin-top:4px">
          <input type="color" id="editStkCHex" value="${hex}" style="width:60px;height:40px;padding:2px;cursor:pointer;border-radius:6px;border:1px solid var(--bdr)" oninput="$('editStkCPreview').style.background=this.value;$('editStkCHexLabel').textContent=this.value">
          <div id="editStkCPreview" style="width:40px;height:40px;border-radius:8px;background:${hex};border:2px solid var(--bdr)"></div>
          <span id="editStkCHexLabel" style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--t3)">${hex}</span>
        </div>
      </div>
    </div>
    <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-p" onclick="saveEditStockColor('${name}')">Save</button></div>
  </div></div>`;
}

function saveEditStockColor(oldName){
  const newName=$('editStkCName').value.trim();
  const newHex=$('editStkCHex').value;
  if(!newName){toast('Name required');return}
  const colors=getStockColors();
  if(newName!==oldName){
    if(colors[newName]){toast('Color name already exists');return}
    delete colors[oldName];
    // Update existing stock items
    let stock=G('al_stock')||[];
    stock=stock.map(s=>s.color===oldName?{...s,color:newName}:s);
    S('al_stock',stock);
  }
  colors[newName]=newHex;
  S('al_stock_colors',colors);
  closeMd();renderSets();toast('Color updated');
}

