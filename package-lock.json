function toast(m){const c=$('toastC');c.innerHTML=`<div class="toast">✓ ${m}</div>`;c.classList.remove('hidden');clearTimeout(c._t);c._t=setTimeout(()=>c.classList.add('hidden'),2800)}

/* ═══════════════════════════════════════
   SIMILAR NUMBER DETECTION
   ═══════════════════════════════════════ */
function digitDiff(a,b){
  // Compare two digit strings, return number of differing digits
  // Pad shorter to match longer
  const maxLen=Math.max(a.length,b.length);
  const pa=a.padStart(maxLen,'0');
  const pb=b.padStart(maxLen,'0');
  if(Math.abs(a.length-b.length)>2) return 99;// Length too different
  let diff=0;
  // Use Levenshtein for proper comparison
  const m=pa.length,n=pb.length;
  const dp=Array.from({length:m+1},()=>Array(n+1).fill(0));
  for(let i=0;i<=m;i++) dp[i][0]=i;
  for(let j=0;j<=n;j++) dp[0][j]=j;
  for(let i=1;i<=m;i++){
    for(let j=1;j<=n;j++){
      dp[i][j]=pa[i-1]===pb[j-1]?dp[i-1][j-1]:1+Math.min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1]);
    }
  }
  return dp[m][n];
}

function findSimilarNumbers(includeApproved){
  const leads=G('al_leads').filter(l=>l.status!=='LOST');
  const approved=G('al_sim_approved')||[];
  const groups=[];
  const processed=new Set();

  for(let i=0;i<leads.length;i++){
    const phoneA=leads[i].phone.replace(/[^0-9]/g,'');
    if(phoneA.length<6||processed.has(i)) continue;

    const similar=[];
    for(let j=i+1;j<leads.length;j++){
      if(processed.has(j)) continue;
      const phoneB=leads[j].phone.replace(/[^0-9]/g,'');
      if(phoneB.length<6) continue;
      if(phoneA===phoneB) continue;

      const diff=digitDiff(phoneA,phoneB);
      if(diff>=1&&diff<=3){
        similar.push({idx:j,lead:leads[j],phone:phoneB,diff});
      }
    }

    if(similar.length){
      // Generate group key from sorted lead IDs
      const ids=[leads[i].id,...similar.map(s=>s.lead.id)].map(Number).sort((a,b)=>a-b).join('-');
      const isApproved=approved.includes(ids);
      if(!includeApproved&&isApproved){processed.add(i);similar.forEach(s=>processed.add(s.idx));continue}
      const group={anchor:{idx:i,lead:leads[i],phone:phoneA},matches:similar,key:ids,approved:isApproved};
      groups.push(group);
      processed.add(i);
      similar.forEach(s=>processed.add(s.idx));
    }
  }
  return groups;
}

function countSimilarNumbers(){
  try{return findSimilarNumbers(false).length}catch(e){return 0}
}

function approveSimilar(key){
  let approved=G('al_sim_approved')||[];
  if(!approved.includes(key)){approved.push(key);S('al_sim_approved',approved)}
  toast('Approved — removed from similar numbers');
  renderSimilar();buildNav();
}

function unapproveSimilar(key){
  let approved=G('al_sim_approved')||[];
  approved=approved.filter(k=>k!==key);
  S('al_sim_approved',approved);
  toast('Approval removed');
  renderSimilar();buildNav();
}

function highlightDiff(phoneA,phoneB){
  const a=phoneA.padStart(Math.max(phoneA.length,phoneB.length),'0');
  const b=phoneB.padStart(Math.max(phoneA.length,phoneB.length),'0');
  let h='';
  for(let i=0;i<b.length;i++){
    if(i<a.length&&a[i]!==b[i]) h+=`<span class="sim-hl">${b[i]}</span>`;
    else h+=b[i];
  }
  return h;
}

function renderSimilar(){
  if(!['director','admin','branch_manager','sales_manager','supervisor'].includes(CU.role)){$('pgC').innerHTML=`<div class="empty"><div class="empty-t">Access Denied</div></div>`;return}
  $('topA').innerHTML='';

  const isSPV=CU.role!=='sales';
  const groups=findSimilarNumbers(false);
  const approvedGroups=findSimilarNumbers(true).filter(g=>g.approved);
  const totalAll=groups.length+approvedGroups.length;

  let h=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="font-size:13px;font-weight:700;color:var(--t1)">🔍 Similar Numbers Detection</div>
    <div style="display:flex;gap:8px;align-items:center">
      <span style="font-size:11px;color:var(--t3)">${groups.length} pending${approvedGroups.length?' · <span style="color:var(--grn)">'+approvedGroups.length+' approved</span>':''}</span>
      ${approvedGroups.length?`<button class="btn btn-s btn-sm" onclick="toggleApproved()">👁 ${$('simApproved')?' Hide':' Show'} Approved</button>`:''}
    </div>
  </div>`;

  if(!groups.length&&!approvedGroups.length){
    h+=`<div class="empty" style="padding:60px 20px"><div class="empty-i">✅</div><div class="empty-t">No similar numbers found</div><div class="empty-s">All phone numbers are sufficiently different</div></div>`;
    $('pgC').innerHTML=h;return;
  }

  if(!groups.length){
    h+=`<div style="background:var(--grn-g);border:1px solid #BBF7D0;border-radius:var(--r);padding:12px;margin-bottom:14px;font-size:12px;color:var(--grn)">✅ All similar numbers have been reviewed and approved.</div>`;
  }

  // Pending groups
  groups.forEach((g,gi)=>{
    const allLeads=[g.anchor,...g.matches];
    h+=`<div class="sim-group">
      <div class="sim-group-head">
        <div class="sim-group-title">⚠ Group ${gi+1} — ${allLeads.length} leads with similar numbers</div>
        ${isSPV?`<button class="btn btn-g btn-sm" onclick="event.stopPropagation();approveSimilar('${g.key}')">✓ Approve</button>`:''}
      </div>`;

    allLeads.forEach((item,ii)=>{
      const l=item.lead;const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
      const phoneDisplay=ii===0?item.phone:highlightDiff(g.anchor.phone,item.phone);
      const diffBadge=item.diff?`<span class="sim-diff">${item.diff} digit${item.diff>1?'s':''} diff</span>`:'<span class="sim-diff" style="background:var(--acc-g);color:var(--acc)">Original</span>';

      h+=`<div class="sim-lead" onclick="openLD(${l.id})">
        <div class="sim-phone">${ii===0?item.phone:phoneDisplay}</div>
        <div class="sim-info"><b>${l.name}</b> · ${l.carType} · <span class="badge" style="background:${sBg(l.status)};color:${sC(l.status)};font-size:9px;padding:1px 6px"><span class="bdot" style="background:${sC(l.status)}"></span>${l.status}</span> · ${l.date}</div>
        <div class="sim-sales">👤 ${u?u.fullName:l.createdBy}${sup?'<br><span style="font-size:9px">Sup: '+sup.fullName+'</span>':''}</div>
        ${diffBadge}
      </div>`;
    });
    h+=`</div>`;
  });

  // Approved groups (hidden by default)
  if(approvedGroups.length){
    h+=`<div id="simApproved" style="display:none">
      <div style="font-size:11px;font-weight:600;color:var(--t3);margin:16px 0 8px;text-transform:uppercase;letter-spacing:.5px">Approved Groups</div>`;
    approvedGroups.forEach((g,gi)=>{
      const allLeads=[g.anchor,...g.matches];
      h+=`<div class="sim-group" style="opacity:.6">
        <div class="sim-group-head">
          <div class="sim-group-title" style="color:var(--grn)">✓ Approved — ${allLeads.length} leads</div>
          ${isSPV?`<button class="btn btn-s btn-sm" onclick="event.stopPropagation();unapproveSimilar('${g.key}')">↩ Undo</button>`:''}
        </div>`;
      allLeads.forEach((item,ii)=>{
        const l=item.lead;const u=userByUn(l.createdBy);
        h+=`<div class="sim-lead" onclick="openLD(${l.id})" style="opacity:.8">
          <div class="sim-phone">${item.phone}</div>
          <div class="sim-info"><b>${l.name}</b> · ${u?u.fullName:l.createdBy}</div>
        </div>`;
      });
      h+=`</div>`;
    });
    h+=`</div>`;
  }

  $('pgC').innerHTML=h;
}

function toggleApproved(){
  const el=$('simApproved');
  if(el) el.style.display=el.style.display==='none'?'block':'none';
}

/* ═══════════════════════════════════════
   DAILY CHECK-IN
   ═══════════════════════════════════════ */
function getCheckins(){return G('al_checkins')||[]}
function doCheckin(){
  const now=new Date();
  const td=now.toISOString().split('T')[0];
  const time=now.toTimeString().slice(0,5);
  let checkins=getCheckins();
  // Only one check-in per user per day
  if(checkins.find(c=>c.user===CU.username&&c.date===td)){toast('Already updated today');return}
  checkins.unshift({user:CU.username,date:td,time});
  S('al_checkins',checkins);
  toast('Daily update confirmed at '+time);
  filtDash();
}

function getLastCheckin(username){
  return getCheckins().find(c=>c.user===username);
}

function isCheckedToday(username){
  const td=new Date().toISOString().split('T')[0];
  return getCheckins().some(c=>c.user===username&&c.date===td);
}

function renderCheckinCard(){
  const isBMSM=['branch_manager','sales_manager'].includes(CU.role);
  const isTop=['director','admin'].includes(CU.role);
  if(!isBMSM&&!isTop)return '';

  const td=new Date().toISOString().split('T')[0];

  if(isBMSM){
    // BM/SM see their own check-in button
    const checked=isCheckedToday(CU.username);
    const last=getLastCheckin(CU.username);
    const checkins=getCheckins().filter(c=>c.user===CU.username);

    // Last 7 days dots
    const dots=[];
    for(let i=6;i>=0;i--){
      const d=new Date();d.setDate(d.getDate()-i);
      const ds=d.toISOString().split('T')[0];
      const isToday=ds===td;
      const done=checkins.some(c=>c.date===ds);
      const dayLabel=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
      dots.push(`<div class="checkin-dot ${done?'yes':'no'} ${isToday?'today':''}" title="${ds}">${dayLabel.slice(0,1)}</div>`);
    }

    return `<div class="checkin-card ${checked?'done':''}">
      <div class="checkin-info">
        <div class="checkin-title">${checked?'✅':'⏳'} Daily Data Update</div>
        <div class="checkin-time">${checked?`Updated today at <b>${checkins.find(c=>c.date===td).time}</b>`:last?`Last update: ${last.date} at ${last.time}`:'No updates yet — please confirm daily'}</div>
        <div class="checkin-log">${dots.join('')}</div>
      </div>
      ${checked?`<button class="checkin-btn completed">✓ Updated</button>`:`<button class="checkin-btn pending" onclick="doCheckin()">📋 Confirm Update</button>`}
    </div>`;
  }

  if(isTop){
    // Director/Admin see all BM/SM check-in status
    const bmsmUsers=G('al_users').filter(u=>['branch_manager','sales_manager'].includes(u.role)&&u.active);
    if(!bmsmUsers.length)return '';
    let h=`<div class="chart-card" style="margin-bottom:16px"><div class="chart-title">Manager Daily Updates</div>`;
    bmsmUsers.forEach(u=>{
      const checked=isCheckedToday(u.username);
      const last=getLastCheckin(u.username);
      const checkins=getCheckins().filter(c=>c.user===u.username);
      const dots=[];
      for(let i=6;i>=0;i--){
        const d=new Date();d.setDate(d.getDate()-i);
        const ds=d.toISOString().split('T')[0];
        const done=checkins.some(c=>c.date===ds);
        const dayLabel=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][d.getDay()];
        dots.push(`<div class="checkin-dot ${done?'yes':'no'} ${ds===td?'today':''}" title="${ds}">${dayLabel.slice(0,1)}</div>`);
      }
      h+=`<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--bdr);flex-wrap:wrap">
        <div class="perf-av rc-${u.role}" style="width:30px;height:30px;font-size:11px">${initials(u.fullName)}</div>
        <div style="flex:1;min-width:0"><div style="font-size:12px;font-weight:600;color:var(--t1)">${u.fullName}</div><div style="font-size:10px;color:var(--t3)">${rLabel(u.role)}</div></div>
        <div class="checkin-log" style="margin-top:0">${dots.join('')}</div>
        <div style="font-size:10px;min-width:0;text-align:right">${checked?`<span style="color:var(--grn);font-weight:600">✅ ${checkins.find(c=>c.date===td).time}</span>`:`<span style="color:var(--red);font-weight:600">⏳ Pending</span>`}</div>
      </div>`;
    });
    h+=`</div>`;
    return h;
  }
  return '';
}

