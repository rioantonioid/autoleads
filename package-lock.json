  let h=`<div class="hbar">📋 <strong>${CU.fullName}</strong> — Supervisor <span class="hbar-sep">→</span> <strong>${team.length}</strong> sales members</div>`;
  h+=`<div class="usr-grid">`;
  team.forEach(u=>{
    const leads=allL.filter(l=>l.createdBy===u.username);const spk=leads.filter(l=>l.status==='SPK').length;
    h+=`<div class="usr-card"><div class="usr-av rc-sales">${initials(u.fullName)}</div><div><div class="usr-name">${u.fullName}</div><div class="usr-meta">@${u.username} · ${leads.length} leads · <span style="color:var(--grn)">${spk} SPK</span></div></div></div>`;
