  err.style.display='none';
  if(!dt){err.textContent='Delivery Order Date is required';err.style.display='block';return}
  if(!window._doPhoto){err.textContent='Delivery photo is required';err.style.display='block';return}
  closeMd();
  let leads=G('al_leads');
  leads=leads.map(l=>Number(l.id)===Number(id)?{...l,doSection:true,doDate:dt,doPhoto:window._doPhoto}:l);
  S('al_leads',leads);
  addActivity(id,'moved','Moved to DO Results (DO Date: '+dt+') — Photo attached');
  window._doPhoto=null;
  toast('Moved to DO Results');
  buildNav();go(PAGE);
}

/* ═══════════════════════════════════════
   DUPLICATE DETECTION
   ═══════════════════════════════════════ */
function findDupes(phone,excludeId){
  if(!phone||phone.length<4) return [];
  const clean=phone.replace(/[^0-9]/g,'');
  if(clean.length<4) return [];
  return G('al_leads').filter(l=>{
    if(excludeId&&l.id===excludeId) return false;
    if(l.status==='LOST') return false;
    const lClean=l.phone.replace(/[^0-9]/g,'');
    return lClean===clean;
  });
}

/* ═══════════════════════════════════════
   PHONE VALIDATION (Indonesian)
   ═══════════════════════════════════════ */
const ID_OPERATORS={
  '0811':'Telkomsel','0812':'Telkomsel','0813':'Telkomsel','0821':'Telkomsel','0822':'Telkomsel','0823':'Telkomsel','0851':'Telkomsel','0852':'Telkomsel','0853':'Telkomsel',
  '0814':'Indosat','0815':'Indosat','0816':'Indosat','0855':'Indosat','0856':'Indosat','0857':'Indosat','0858':'Indosat',
  '0817':'XL','0818':'XL','0819':'XL','0859':'XL','0877':'XL','0878':'XL','0879':'XL',
  '0831':'Axis','0832':'Axis','0833':'Axis','0838':'Axis',
  '0895':'Three','0896':'Three','0897':'Three','0898':'Three','0899':'Three',
  '0881':'Smartfren','0882':'Smartfren','0883':'Smartfren','0884':'Smartfren','0885':'Smartfren','0886':'Smartfren','0887':'Smartfren','0888':'Smartfren','0889':'Smartfren',
};

function validatePhone(phone){
  if(!phone) return {valid:false,msg:'Phone number is required',operator:null};
  let clean=phone.replace(/[^0-9+]/g,'');
  // Convert +62 to 0
  if(clean.startsWith('+62')) clean='0'+clean.slice(3);
  if(clean.startsWith('62')&&clean.length>10) clean='0'+clean.slice(2);

  if(!clean.startsWith('0')) return {valid:false,msg:'Must start with 0 or +62',operator:null,clean};
  if(clean.length<10) return {valid:false,msg:'Too short — need at least 10 digits',operator:null,clean};
  if(clean.length>13) return {valid:false,msg:'Too long — maximum 13 digits',operator:null,clean};

  // Check operator prefix (first 4 digits)
  const prefix=clean.slice(0,4);
  const operator=ID_OPERATORS[prefix];
  if(!operator) return {valid:false,msg:`Unknown prefix ${prefix} — not a recognized Indonesian operator`,operator:null,clean};

  return {valid:true,msg:null,operator,clean};
}

function showPhoneValidation(phone,excludeId){
  const vw=$('phoneValid');
  if(!vw){checkDupeLive(phone,excludeId);return}
  if(!phone||phone.length<3){vw.innerHTML='';checkDupeLive(phone,excludeId);return}

  const v=validatePhone(phone);
  if(v.valid){
    vw.innerHTML=`<div style="font-size:10px;padding:4px 0;color:var(--grn);font-weight:600">✓ Valid — ${v.operator}</div>`;
  }else{
    vw.innerHTML=`<div style="font-size:10px;padding:4px 0;color:var(--org);font-weight:600">⚠ ${v.msg}</div>`;
  }
  checkDupeLive(phone,excludeId);
}

function checkDupeLive(phone,excludeId){
  const w=$('dupeWarn');if(!w)return;
  if(!phone||phone.length<4){w.innerHTML='';return}
  fetch(`/api/check-phone?phone=${encodeURIComponent(phone)}&excludeId=${excludeId||0}`,{credentials:'same-origin'}).then(r=>r.json()).then(dupes=>{
  if(!dupes.length){w.innerHTML='';return}
  const blocked=CU.role==='sales';
  w.innerHTML=`<div class="dupe-warn" style="${blocked?'border-color:var(--red);background:rgba(239,68,68,.08)':''}">⚠️ <b>${blocked?'🚫 BLOCKED — Duplicate number!':'Duplicate found!'}</b> This phone number already exists:${blocked?'<div style="font-size:10px;color:var(--red);font-weight:700;margin:4px 0">You cannot save a lead with a duplicate phone number.</div>':''}<div>${dupes.map(d=>{
    const u=userByUn(d.createdBy);
    return `<div class="dupe-item"><div><span class="dupe-name">${d.name}</span> — ${d.phone}<br>Status: ${d.status} · Source: ${d.source}</div><div style="text-align:right">${u?u.fullName:d.createdBy}<br><span style="font-size:9px;color:var(--t4)">${d.createdAt}</span></div></div>`;
  }).join('')}</div></div>`;
  }).catch(()=>{});
}

function isDupe(leadId){
  const l=G('al_leads').find(x=>x.id===leadId);if(!l)return false;
  return findDupes(l.phone,l.id).length>0;
}

function saveL(id){
  const name=$('fN').value.trim(),phone=$('fP').value.trim();
  if(!name||!phone){toast('Name & Phone required');return}
  fetch(`/api/check-phone?phone=${encodeURIComponent(phone)}&excludeId=${id||0}`,{credentials:'same-origin'}).then(r=>r.json()).then(dupes=>{
    if(dupes.length&&!id){
      if(CU.role==='sales'){toast('This phone number already exists. Duplicate leads are not allowed.');return}
      const dn=dupes.map(d=>`• ${d.name} (${d.phone}) — by ${d.salesName||d.createdBy} [${d.status}]`).join('\n');
      if(!confirm(`⚠️ DUPLICATE\n\n${dn}\n\nStill save?`))return;
    }
    doSaveL(id,name,phone);
  }).catch(()=>doSaveL(id,name,phone));
}
function doSaveL(id,name,phone){
  const now=new Date().toISOString().split('T')[0];
  const d={name,phone,carType:$('fCT').value,source:$('fSo').value,status:$('fStt').value,date:$('fD').value,followUp:$('fFU').value,notes:$('fNo').value.trim(),updatedAt:now,updatedBy:CU.username};
  let leads=G('al_leads');
  if(id){
    const old=leads.find(l=>Number(l.id)===Number(id));
    leads=leads.map(l=>Number(l.id)===Number(id)?{...l,...d}:l);
    if(old&&old.status!==d.status) addActivity(id,'status','Status changed: '+old.status+' → '+d.status);
    addActivity(id,'edit','Lead updated');
    toast('Lead updated');
  }else{
    const nid=Date.now();
    leads.unshift({...d,id:nid,createdBy:CU.username,createdAt:now});
    addActivity(nid,'created','Lead created');
    // Auto-remove LOST leads with same phone number
    const cleanPhone=phone.replace(/[^0-9]/g,'');
    const lostMatches=leads.filter(l=>Number(l.id)!==nid&&l.status==='LOST'&&!l.spkSection&&!l.doSection&&l.phone.replace(/[^0-9]/g,'')===cleanPhone);
    if(lostMatches.length){
      leads=leads.filter(l=>!lostMatches.some(lm=>Number(lm.id)===Number(l.id)));
      lostMatches.forEach(lm=>addActivity(nid,'status','Auto-removed LOST lead ('+lm.name+' by '+(userByUn(lm.createdBy)?userByUn(lm.createdBy).fullName:lm.createdBy)+') — same phone re-entered'));
      toast('Lead added + '+lostMatches.length+' LOST lead'+(lostMatches.length>1?'s':'')+' removed');
    }else{
      toast('Lead added');
    }
  }
  S('al_leads',leads);closeMd();buildNav();go(PAGE);
}
function delL(id){
  id=Number(id);
  closeDt();
  setTimeout(()=>{
    $('modalC').classList.remove('hidden');
    $('modalC').innerHTML=`<div class="mo" onclick="if(event.target===this)closeMd()"><div class="md" style="max-width:380px">
      <div class="md-h"><span class="md-t">🗑 Delete Lead</span><button class="md-x" onclick="closeMd()">✕</button></div>
      <div class="md-b">
        <div style="font-size:13px;color:var(--t2);text-align:center;padding:10px 0">Are you sure you want to delete this lead?<br><span style="font-size:11px;color:var(--t4)">This action cannot be undone.</span></div>
      </div>
      <div class="md-f"><button class="btn btn-s" onclick="closeMd()">Cancel</button><button class="btn btn-d" onclick="confirmDelL(${id})">Delete</button></div>
    </div></div>`;
  },100);
}

function confirmDelL(id){
  id=Number(id);
  let leads=G('al_leads');
  const before=leads.length;
  leads=leads.filter(l=>Number(l.id)!==id);
  S('al_leads',leads);
  S('al_activities',(G('al_activities')||[]).filter(a=>Number(a.leadId)!==id));
  closeMd();
  toast('Lead deleted ('+(before-leads.length)+' removed)');
  buildNav();go(PAGE);
}

/* ═══════════════════════════════════════
   LEAD DETAIL
   ═══════════════════════════════════════ */
function openLD(id){
  const l=G('al_leads').find(x=>Number(x.id)===Number(id));if(!l)return;
  const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
  const sts=G('al_statuses');
  const isSPV=CU.role!=='sales';
  // Sales can edit own leads ONLY if NOT in SPK/DO section
  const canE=(isSPV||(CU.role==='sales'&&l.createdBy===CU.username))&&!l.spkSection&&!l.doSection;
  // SPV+ can always edit SPK/DO leads
  const canESPV=isSPV&&(l.spkSection||l.doSection);
  const canEdit=canE||canESPV;
  const dupes=findDupes(l.phone,l.id);
  const dupeHtml=dupes.length?`<div class="dupe-warn" style="margin-bottom:12px">⚠️ <b>DUPLICATE — This phone number exists in ${dupes.length} other lead${dupes.length>1?'s':''}:</b>${dupes.map(d=>{const du=userByUn(d.createdBy);return `<div class="dupe-item"><div><span class="dupe-name">${d.name}</span> — ${d.phone}<br>Status: ${d.status} · Source: ${d.source}</div><div style="text-align:right">${du?du.fullName:d.createdBy}<br><span style="font-size:9px;color:var(--t4)">${d.createdAt}</span></div></div>`}).join('')}</div>`:'';

  // Action buttons
  let actionBtns='';
  const canMoveSPK=l.status==='SPK'&&!l.spkSection&&!l.doSection&&(isSPV||(CU.role==='sales'&&l.createdBy===CU.username));
  if(canMoveSPK) actionBtns+=`<button class="btn-spk" onclick="event.stopPropagation();moveToSPK(${l.id})">📦 Move to SPK Results</button>`;
  if(l.spkSection&&!l.doSection) actionBtns+=`<button class="btn-do" onclick="event.stopPropagation();moveToDelivery(${l.id})">🚚 Delivery Order</button>`;
  if(l.spkSection&&!l.doSection&&isSPV) actionBtns+=`<button class="btn btn-s btn-sm" onclick="event.stopPropagation();moveFromSPK(${l.id})">↩ Return</button>`;

  // Section badge
  let secBadge='';
  if(l.doSection) secBadge=' <span class="badge" style="background:var(--pur-g);color:var(--pur);font-size:9px">🚚 DO</span>';
  else if(l.spkSection) secBadge=' <span class="badge" style="background:var(--grn-g);color:var(--grn);font-size:9px">📦 SPK</span>';

  // Activity log
  const acts=getActivities(l.id);
  const actColors={created:'var(--grn)',status:'var(--acc)',edit:'var(--org)',note:'var(--pur)',moved:'var(--cyn)'};
  const actHtml=`<div class="ds"><div class="ds-t">Activity Log</div>
    <div class="act-add"><input class="fi" id="actInput" placeholder="Add activity note..." style="font-size:11px;padding:8px 10px" onkeydown="if(event.key==='Enter')addNote(${l.id})"><button class="btn btn-p btn-sm" onclick="addNote(${l.id})">Add</button></div>
    <div class="act-log">${acts.length?acts.map(a=>{const au=userByUn(a.user);return `<div class="act-item"><div class="act-dot" style="background:${actColors[a.action]||'var(--t4)'}"></div><div class="act-body"><div class="act-text">${a.action==='note'?`<b>${au?au.fullName:a.user}:</b> ${a.detail}`:a.action==='status'?`<b>${au?au.fullName:a.user}</b> ${a.detail}`:a.action==='moved'?`<b>${au?au.fullName:a.user}</b> ${a.detail}`:a.action==='created'?`<b>${au?au.fullName:a.user}</b> created this lead`:`<b>${au?au.fullName:a.user}</b> ${a.detail}`}</div><div class="act-meta">${a.date} ${a.time}</div></div></div>`}).join(''):'<div style="font-size:11px;color:var(--t4);padding:8px 0">No activity yet</div>'}</div></div>`;

  // Detail fields
  const pv=validatePhone(l.phone);
  const phoneDisplay=l.phone+(pv.valid?` <span style="font-size:9px;color:var(--grn);font-weight:600">(${pv.operator})</span>`:`<span style="font-size:9px;color:var(--org);font-weight:600"> ⚠ ${pv.msg||'Invalid'}</span>`);
  const fields=[{l:'Phone',v:phoneDisplay},{l:'Car Type',v:l.carType},{l:'Source',v:`<span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:10px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span>`},{l:'Date',v:l.date},{l:'Follow Up',v:fuCountdown(l.followUp)+(l.followUp?` <span style="font-size:9px;color:var(--t4)">(${l.followUp})</span>`:'')},{l:'Sales Person',v:u?`${u.fullName} <span class="badge rc-${u.role}" style="font-size:8px;padding:1px 6px">${rLabel(u.role)}</span>`:l.createdBy},{l:'Supervisor',v:sup?sup.fullName:'—'},{l:'Created',v:l.createdAt}];
  if(l.spkDate) fields.push({l:'SPK Date',v:`<span style="color:var(--grn);font-weight:600">${l.spkDate}</span>`});
  if(l.doDate) fields.push({l:'DO Date',v:`<span style="color:var(--pur);font-weight:600">${l.doDate}</span>`});

  $('detailC').classList.remove('hidden');
  $('detailC').innerHTML=`<div class="dp">
    <div class="dp-h"><div><div style="font-size:17px;font-weight:700">${l.name}${dupes.length?' <span class="dupe-badge" style="font-size:10px;padding:3px 8px">⚠ DUPLICATE</span>':''}${secBadge}</div><div style="font-size:12px;color:var(--t3);margin-top:2px">${l.phone}</div></div>
    <div style="display:flex;gap:4px;flex-shrink:0;align-items:center;flex-wrap:wrap">
      ${actionBtns}
      ${canEdit?`<button class="btn btn-s btn-sm" onclick="openLF(${l.id})">Edit</button><button class="btn btn-d btn-sm" onclick="delL(${l.id})">Del</button>`:''}
      <button class="btn-icon" onclick="closeDt()" style="width:28px;height:28px">✕</button>
    </div></div>
    <div class="dp-b">
      ${dupeHtml}
      <div class="ds"><span class="badge" style="background:${sBg(l.status)};color:${sC(l.status)};font-size:11px;padding:5px 13px"><span class="bdot" style="background:${sC(l.status)}"></span>${l.status}</span></div>
      <div class="ds"><div class="ds-t">Details</div>
        ${fields.map(f=>`<div class="df"><div><div class="df-l">${f.l}</div><div class="df-v">${f.v}</div></div></div>`).join('')}
      </div>
      ${l.notes?`<div class="ds"><div class="ds-t">Notes</div><div style="font-size:12px;line-height:1.6;color:var(--t2);background:var(--bg3);padding:10px 12px;border-radius:var(--r);border:1px solid var(--bdr)">${l.notes}</div></div>`:''}
      ${l.doPhoto?`<div class="ds"><div class="ds-t">📷 Delivery Photo</div><div style="background:var(--bg3);border:1px solid var(--bdr);border-radius:var(--r);padding:8px;cursor:pointer" onclick="viewDOPhoto(${l.id})"><img src="${l.doPhoto}" style="width:100%;max-height:250px;object-fit:cover;border-radius:6px" alt="Delivery photo"><div style="font-size:10px;color:var(--t4);margin-top:4px;text-align:center">Tap to view full size</div></div></div>`:''}      ${canEdit&&!l.doSection?`<div class="ds"><div class="ds-t">Update Status</div><div class="spills">${sts.map(s=>`<button class="spill ${l.status===s?'act':''}" style="${l.status===s?`background:${sC(s)}`:''}" onclick="updSt(${l.id},'${s}')">${s}</button>`).join('')}</div></div>`:''}
      ${actHtml}
    </div>
  </div>`;
}
function updSt(id,s){
  const now=new Date().toISOString().split('T')[0];
  let leads=G('al_leads');
  const old=leads.find(l=>Number(l.id)===Number(id));
  const oldSt=old?old.status:'';
  leads=leads.map(l=>Number(l.id)===Number(id)?{...l,status:s,updatedAt:now,updatedBy:CU.username}:l);
  S('al_leads',leads);
  addActivity(id,'status','Status changed: '+oldSt+' → '+s);
  toast('Status → '+s);openLD(id);buildNav();
}

/* ═══════════════════════════════════════
   SPK SECTION
   ═══════════════════════════════════════ */
function renderSPK(){
  $('topA').innerHTML=pExport()?`<button class="btn btn-s btn-sm" onclick="expCSV('spk')">📥 Export SPK</button>`:'';
  const allSpk=getVisibleLeads().filter(l=>l.spkSection&&!l.doSection);

  let supDD='',salesDD='';
  if(pViewAll()){
    const sups=G('al_users').filter(u=>u.role==='supervisor'&&u.active);
    const salesUsers=G('al_users').filter(u=>u.role==='sales'&&u.active);
    supDD=`<select class="fd" id="spkSup" onchange="onSupChange('spk','filtSPK')"><option value="All">All Supervisors</option>${sups.map(s=>`<option value="${s.id}">${s.fullName}</option>`).join('')}</select>`;
    salesDD=`<select class="fd" id="spkSales" onchange="filtSPK()"><option value="All">All Sales</option>${salesUsers.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }else if(CU.role==='supervisor'){
    const teamSales=G('al_users').filter(u=>u.role==='sales'&&u.supervisorId===CU.id&&u.active);
    salesDD=`<select class="fd" id="spkSales" onchange="filtSPK()"><option value="All">All Sales</option>${teamSales.map(u=>`<option value="${u.username}">${u.fullName}</option>`).join('')}</select>`;
  }

  let h=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-wrap:wrap;gap:8px">
    <div style="display:flex;gap:10px;align-items:center">
      <div style="font-size:13px;font-weight:700;color:var(--t1)">SPK Results</div>
      <div class="view-tog"><button class="${spkViewMode==='cards'?'act':''}" onclick="spkViewMode='cards';filtSPK()">Cards</button><button class="${spkViewMode==='compact'?'act':''}" onclick="spkViewMode='compact';filtSPK()">Compact</button></div>
    </div>
    <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap">
      <div class="sb"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input id="spkSrch" placeholder="Search..." oninput="filtSPK()"></div>
      <select class="fd" id="spkMonth" onchange="filtSPK()">${monthOpts(allSpk)}</select>
      ${supDD}${salesDD}
    </div>
  </div>`;
  h+=`<div id="spkBody"></div>`;
  $('pgC').innerHTML=h;
  filtSPK();
}

function filtSPK(){
  const allSpk=getVisibleLeads().filter(l=>l.spkSection&&!l.doSection);
  const q=($('spkSrch')?.value||'').toLowerCase();
  const mon=$('spkMonth')?.value||'All';
  const supF=$('spkSup')?.value||'All';
  const sal=$('spkSales')?.value||'All';
  const leads=allSpk.filter(l=>{
    if(q&&!l.name.toLowerCase().includes(q)&&!l.phone.includes(q))return false;
    if(mon!=='All'&&!l.date.startsWith(mon))return false;
    if(sal!=='All'&&l.createdBy!==sal)return false;
    if(supF!=='All'){const u=userByUn(l.createdBy);if(!u||u.supervisorId!==Number(supF))return false}
    return true;
  });
  const body=$('spkBody');if(!body)return;

  if(!leads.length){
    body.innerHTML=`<div class="empty" style="padding:60px 20px"><div class="empty-i">📦</div><div class="empty-t">No SPK found</div><div class="empty-s">${allSpk.length?'Try a different filter':'Leads moved to SPK Results will appear here'}</div></div>`;
    return;
  }
  let h=`<div style="margin-bottom:10px;font-size:12px;color:var(--t3)">${leads.length} SPK found</div>`;
  if(spkViewMode==='compact'){
    h+=`<div style="overflow-x:auto"><table class="cpt-tbl"><thead><tr><th>Name</th><th>Phone</th><th>Car</th><th>Source</th><th>Sales</th><th>Supervisor</th><th>Lead Date</th><th>SPK Date</th><th>Action</th></tr></thead><tbody>`;
    leads.forEach(l=>{
      const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
      h+=`<tr onclick="openLD(${l.id})"><td class="cpt-name">${l.name}</td><td class="cpt-phone">${l.phone}</td><td>${l.carType}</td><td><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:8px;padding:1px 5px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></td><td>${u?u.fullName:l.createdBy}</td><td>${sup?sup.fullName:'—'}</td><td class="cpt-date" style="color:var(--t2)">${l.date}</td><td class="cpt-date" style="color:var(--grn)">${l.spkDate||'—'}</td><td><button class="btn-do" onclick="event.stopPropagation();moveToDelivery(${l.id})" style="padding:3px 8px;font-size:9px">🚚 DO</button></td></tr>`;
    });
    h+=`</tbody></table></div>`;
  }else{
  leads.forEach(l=>{
    const u=userByUn(l.createdBy);const sup=u?userById(u.supervisorId):null;
    const acts=getActivities(l.id);const lastAct=acts.length?acts[0]:null;
    h+=`<div class="spk-card" onclick="openLD(${l.id})">
      <div class="spk-head"><div><div class="spk-name">${l.name}</div><div class="spk-phone">${l.phone}</div></div>
      <div style="display:flex;gap:6px;align-items:center">
        <button class="btn-do" onclick="event.stopPropagation();moveToDelivery(${l.id})" style="padding:6px 14px;font-size:11px">🚚 Delivery Order</button>
        <span class="badge" style="background:${sBg(l.status)};color:${sC(l.status)}"><span class="bdot" style="background:${sC(l.status)}"></span>${l.status}</span>
      </div></div>
      <div class="spk-details">
        <span>🚗 ${l.carType}</span>
        <span><span class="badge" style="background:${srcBg(l.source)};color:${srcC(l.source)};font-size:9px;padding:2px 6px"><span class="bdot" style="background:${srcC(l.source)}"></span>${l.source}</span></span>
        <span>👤 ${u?u.fullName:l.createdBy}</span>
        ${sup?`<span>📋 ${sup.fullName}</span>`:''}
      </div>
      <div style="display:flex;gap:16px;margin-top:8px;padding-top:8px;border-top:1px solid var(--bdr);font-size:11px">
        <div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">Lead Date</span><div style="font-weight:600;color:var(--t2);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.date}</div></div>
        ${l.spkDate?`<div><span style="color:var(--t4);font-size:9px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap">SPK Date</span><div style="font-weight:700;color:var(--grn);font-family:'JetBrains Mono',monospace;margin-top:2px">${l.spkDate}</div></div>`:''}
      </div>
      ${lastAct?`<div style="margin-top:8px;font-size:10px;color:var(--t4);border-top:1px solid var(--bdr);padding-top:6px">Last activity: ${lastAct.detail} — ${lastAct.date} ${lastAct.time}</div>`:''}
    </div>`;
  });
  } // end cards view
  body.innerHTML=h;
}

